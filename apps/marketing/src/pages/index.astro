---
import Layout from "../layouts/Layout.astro";
import ProviderFloat from "../components/ProviderFloat.astro";
---

<Layout
  title="ace — Agentic coding workbench"
  description="ace is a product-specific workbench for coding agents: project threads, provider sessions, terminal context, browser checks, editor review, GitHub workflows, remote access, and recovery in one place."
>
  <section class="hero" aria-labelledby="hero-heading">
    <nav class="site-nav" aria-label="Primary">
      <a href="/" class="brand" aria-label="ace home">
        <img src="/logo.png" alt="" class="brand-icon" />
        <span>ace</span>
      </a>
      <div class="nav-links">
        <a href="#workspace">Workspace</a>
        <a href="#features">Features</a>
        <a href="#remote">Remote</a>
        <a href="/changelog">Changelog</a>
        <a href="https://github.com/arpan404/ace" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </nav>

    <div class="hero-shell">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">Agentic coding environment</p>
        <h1 id="hero-heading">The desk for every coding agent.</h1>
        <p class="hero-intro">
          ace keeps project threads, provider runtimes, approvals, terminals, browser checks,
          editor context, GitHub handoff, and recovery attached to the repo where the work happens.
        </p>
        <div class="hero-actions" aria-label="Primary actions">
          <a id="download-btn" href="/download" class="button button-primary">
            <svg class="cta-icon cta-icon--apple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" aria-hidden="true"><path fill="currentColor" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>
            <svg class="cta-icon cta-icon--windows" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/></svg>
            <span id="download-label">Download ace</span>
          </a>
          <a href="#workspace" class="button button-secondary">See the workflow</a>
        </div>
      </div>

      <div class="hero-product" data-hero-stage aria-label="Ace product preview">
        <div class="app-chrome" aria-hidden="true">
          <span></span><span></span><span></span>
          <strong>ace://project/thread</strong>
        </div>
        <div class="product-screen">
          <div class="project-rail" aria-hidden="true">
            <span class="rail-logo">ace</span>
            <span class="rail-search">Search</span>
            <span class="rail-section">Pinned threads</span>
            <span class="rail-item active">Refactor provider picker</span>
            <span class="rail-item">Fix browser storage</span>
            <span class="rail-section">Projects</span>
            <span class="rail-item">ace</span>
            <span class="rail-item">mobile-host</span>
          </div>
          <div class="thread-stage" aria-hidden="true">
            <div class="thread-topline">
              <span>Provider</span>
              <strong>Codex · GPT-5.4</strong>
              <em>full access</em>
            </div>
            <div class="timeline">
              <div class="timeline-row user">Redesign the model picker and verify the UI in browser.</div>
              <div class="timeline-row plan">Plan ready · approval requested</div>
              <div class="timeline-row tool">Read ProviderModelPicker.tsx</div>
              <div class="timeline-row terminal">Terminal · bun fmt · bun lint · bun typecheck</div>
              <div class="timeline-row diff">Checkpoint ready · +42 -17</div>
            </div>
            <div class="composer-strip">
              <span>Ask anything, @tag files, attach terminal context</span>
              <strong>Running</strong>
            </div>
          </div>
          <div class="surface-stack" aria-hidden="true">
            <div class="surface browser-surface">
              <span>Browser</span>
              <strong>localhost:5173</strong>
              <i></i>
            </div>
            <div class="surface editor-surface">
              <span>Editor</span>
              <strong>Workspace diff</strong>
              <i></i>
            </div>
            <div class="surface terminal-surface">
              <span>Terminal</span>
              <strong>2 open · 1 running</strong>
              <i></i>
            </div>
          </div>
        </div>
        <div class="hero-label label-left" aria-hidden="true">project context stays attached</div>
        <div class="hero-label label-right" aria-hidden="true">runtime events stay visible</div>
      </div>
    </div>

    <div class="capability-strip" aria-label="Ace product capabilities">
      <span>Codex app-server sessions</span>
      <span>Claude, Gemini, Cursor, Copilot, OpenCode</span>
      <span>Terminal context</span>
      <span>Browser verification</span>
      <span>Workspace editor</span>
      <span>GitHub issues and PRs</span>
      <span>Remote mobile control</span>
    </div>
  </section>

  <section class="provider-band" aria-labelledby="providers-heading">
    <div class="section-head narrow" data-reveal>
      <p class="eyebrow">Bring the CLIs you already use</p>
      <h2 id="providers-heading">No lock-in. One operating layer.</h2>
      <p>
        ace wraps provider sessions behind a single project workflow, so teams can pick the agent
        that fits a task without changing how they review, recover, or hand off the work.
      </p>
    </div>
    <ProviderFloat />
  </section>

  <section id="workspace" class="workspace-band" aria-labelledby="workspace-heading">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Core workspace</p>
      <h2 id="workspace-heading">A coding-agent run is more than a chat.</h2>
      <p>
        The product is shaped around the real lifecycle: choose a repo, start a provider session,
        inspect the plan, approve tool work, verify changes, and recover when a turn gets interrupted.
      </p>
    </div>

    <div class="runway" data-pin-runway>
      <article class="runway-step" data-step>
        <span>01</span>
        <h3>Project threads</h3>
        <p>Each thread carries its project root, branch, worktree, model selection, provider status, and history.</p>
      </article>
      <article class="runway-step" data-step>
        <span>02</span>
        <h3>Runtime visibility</h3>
        <p>Plans, approvals, tool calls, user input, provider errors, queued steering, and live turns are projected into one timeline.</p>
      </article>
      <article class="runway-step" data-step>
        <span>03</span>
        <h3>Integrated review</h3>
        <p>Terminal output, browser tabs, workspace editor panes, changed files, and diffs stay close to the conversation.</p>
      </article>
      <article class="runway-step" data-step>
        <span>04</span>
        <h3>Clean recovery</h3>
        <p>Checkpoints, transcript rebuilds, reconnects, archive flows, and provider handoffs protect long-running work.</p>
      </article>
    </div>
  </section>

  <section id="features" class="feature-system" aria-labelledby="features-heading">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Feature system</p>
      <h2 id="features-heading">Purpose-built surfaces for agent work.</h2>
    </div>

    <div class="feature-mosaic">
      <article class="feature-panel tall" data-feature>
        <div class="panel-visual timeline-visual" aria-hidden="true">
          <span class="pulse-dot"></span>
          <div>User message</div>
          <div>Proposed plan</div>
          <div>Approval request</div>
          <div>Tool result</div>
          <div>Checkpoint diff</div>
        </div>
        <h3>Operational timelines</h3>
        <p>ace turns provider streams into durable orchestration events, so a thread remains readable after reconnects and restarts.</p>
      </article>

      <article class="feature-panel wide" data-feature>
        <div class="panel-visual split-visual" aria-hidden="true">
          <div><span>Browser</span><strong>tab state per thread</strong></div>
          <div><span>Editor</span><strong>workspace tree and Monaco panes</strong></div>
          <div><span>Terminal</span><strong>history, title, cwd, resize</strong></div>
        </div>
        <h3>Browser, editor, and terminal in the loop</h3>
        <p>UI checks, code review, scripts, logs, and terminal excerpts become promptable context instead of scattered side quests.</p>
      </article>

      <article class="feature-panel" data-feature>
        <div class="panel-visual github-visual" aria-hidden="true">
          <span>issue #128</span>
          <span>checkout PR</span>
          <span>generate title/body</span>
        </div>
        <h3>GitHub-aware workflows</h3>
        <p>Open issues, fetch issue threads, prepare pull request workspaces, create PR copy, and keep branch context visible.</p>
      </article>

      <article class="feature-panel" data-feature>
        <div class="panel-visual approval-visual" aria-hidden="true">
          <strong>approve?</strong>
          <span>command_execution</span>
          <span>file_change</span>
          <span>apply_patch</span>
        </div>
        <h3>Approval modes with intent</h3>
        <p>Run approval-required or full-access modes while preserving explicit policy, pending approvals, and failed responses.</p>
      </article>
    </div>
  </section>

  <section id="remote" class="remote-band" aria-labelledby="remote-heading">
    <div class="remote-copy" data-reveal>
      <p class="eyebrow">Desktop-first. Remote-ready.</p>
      <h2 id="remote-heading">Walk away from the desk without losing the run.</h2>
      <p>
        The desktop host manages local agents and remote hosts. URL/web mode and the Expo mobile app
        connect over WebSocket RPC with pairing links, QR import, host switching, and project agent counts.
      </p>
    </div>
    <div class="remote-visual" data-feature aria-hidden="true">
      <div class="host-node desktop-node">
        <span>Desktop host</span>
        <strong>ace serve</strong>
      </div>
      <div class="connection-line"></div>
      <div class="phone-frame">
        <span>Projects</span>
        <div>Working · 4</div>
        <div>Pending · 2</div>
        <div>Completed · 18</div>
      </div>
      <div class="host-node web-node">
        <span>Web mode</span>
        <strong>single remote host</strong>
      </div>
    </div>
  </section>

  <section class="reliability-band" aria-labelledby="reliability-heading">
    <div class="section-head narrow" data-reveal>
      <p class="eyebrow">Reliability is a feature</p>
      <h2 id="reliability-heading">Designed for partial streams, stale state, and long histories.</h2>
    </div>
    <div class="reliability-grid">
      <div data-feature><span>Snapshot cache</span><strong>lean hydration for large thread lists</strong></div>
      <div data-feature><span>Provider runtime</span><strong>restart and resume cursors</strong></div>
      <div data-feature><span>Checkpoints</span><strong>turn diffs and restore language per provider</strong></div>
      <div data-feature><span>Notifications</span><strong>attention prompts for approvals and input</strong></div>
      <div data-feature><span>Browser storage</span><strong>repair and preserve app tabs</strong></div>
      <div data-feature><span>Worktrees</span><strong>cleanup and PR branch workflows</strong></div>
    </div>
  </section>

  <section class="final-cta" aria-labelledby="final-heading">
    <div class="final-copy" data-reveal>
      <p class="eyebrow">Start local. Scale across providers.</p>
      <h2 id="final-heading">Put every agent run in one inspectable workspace.</h2>
      <p>Install ace, connect your provider CLIs, and keep prompt, patch, review, and recovery in one product.</p>
    </div>
    <a href="/download" class="button button-primary">Download ace</a>
  </section>
</Layout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  type Platform = { os: "mac" | "win" | "linux"; label: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) return { os: "mac", label: "Download for macOS" };
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  function initDownloadLink() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    const platform = detectPlatform();
    if (!btn || !label || !platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;
  }

  function initMotion() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo(
      "[data-hero-stage]",
      { y: 46, rotateX: 8, opacity: 0 },
      { y: 0, rotateX: 0, opacity: 1, duration: 0.9, ease: "power3.out" },
    );

    gsap.utils.toArray<HTMLElement>("[data-reveal]").forEach((element) => {
      gsap.fromTo(
        element,
        { y: 34, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.68,
          ease: "power3.out",
          scrollTrigger: { trigger: element, start: "top 86%" },
        },
      );
    });

    gsap.utils.toArray<HTMLElement>("[data-step]").forEach((step, index) => {
      gsap.fromTo(
        step,
        { y: 50, opacity: 0.35 },
        {
          y: 0,
          opacity: 1,
          duration: 0.62,
          delay: index * 0.05,
          ease: "power3.out",
          scrollTrigger: { trigger: step, start: "top 88%" },
        },
      );
    });

    gsap.utils.toArray<HTMLElement>("[data-feature]").forEach((element) => {
      gsap.fromTo(
        element,
        { y: 46, opacity: 0.5, scale: 0.985 },
        {
          y: 0,
          opacity: 1,
          scale: 1,
          ease: "none",
          scrollTrigger: {
            trigger: element,
            start: "top 92%",
            end: "top 52%",
            scrub: true,
          },
        },
      );
    });

    gsap.to(".surface", {
      y: -8,
      duration: 2.4,
      ease: "sine.inOut",
      yoyo: true,
      repeat: -1,
      stagger: 0.28,
    });
  }

  initDownloadLink();
  initMotion();
</script>

<style>
  .hero,
  .provider-band,
  .workspace-band,
  .feature-system,
  .remote-band,
  .reliability-band,
  .final-cta {
    width: min(100% - 2rem, 1240px);
    margin: 0 auto;
  }

  .hero {
    min-height: 100dvh;
    padding: clamp(1rem, 2vw, 1.5rem) 0 clamp(3rem, 7vw, 6rem);
  }

  .site-nav {
    position: relative;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4rem;
    border-bottom: 1px solid var(--line);
  }

  .brand,
  .nav-links,
  .hero-actions,
  .button,
  .app-chrome,
  .thread-topline,
  .composer-strip,
  .capability-strip {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 0.7rem;
    font-size: 1.05rem;
    font-weight: 800;
  }

  .brand-icon {
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 7px;
  }

  .nav-links {
    gap: clamp(0.75rem, 2vw, 1.5rem);
    color: var(--fg-muted);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .nav-links a {
    transition: color 160ms ease;
  }

  .nav-links a:hover {
    color: var(--fg);
  }

  .hero-shell {
    position: relative;
    display: grid;
    grid-template-columns: minmax(19rem, 0.78fr) minmax(32rem, 1.22fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    min-height: clamp(43rem, 84vh, 58rem);
    isolation: isolate;
  }

  .hero-shell::before {
    content: "";
    position: absolute;
    inset: 5% -8% 2%;
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(44, 157, 255, 0.13), transparent 35%),
      linear-gradient(180deg, transparent, rgba(80, 255, 185, 0.06));
    clip-path: polygon(0 0, 100% 10%, 90% 100%, 6% 86%);
  }

  .hero-copy {
    display: grid;
    gap: 1.25rem;
    max-width: 40rem;
  }

  .eyebrow {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero h1,
  .section-head h2,
  .remote-copy h2,
  .final-copy h2 {
    color: var(--fg);
    font-size: clamp(4rem, 8vw, 8.2rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.84;
    text-wrap: balance;
  }

  .hero-intro,
  .section-head p,
  .runway-step p,
  .feature-panel p,
  .remote-copy p,
  .final-copy p {
    color: var(--fg-muted);
    font-size: clamp(1rem, 1.25vw, 1.13rem);
    line-height: 1.62;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button {
    min-height: 3.1rem;
    justify-content: center;
    gap: 0.64rem;
    border: 1px solid transparent;
    border-radius: 7px;
    padding: 0.88rem 1.1rem;
    font-weight: 800;
    line-height: 1;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button-primary {
    background: var(--fg);
    color: var(--ink);
  }

  .button-secondary {
    border-color: var(--line-strong);
    background: rgba(242, 238, 228, 0.035);
    color: var(--fg);
  }

  .cta-icon {
    display: none;
    width: 1rem;
    height: 1rem;
  }

  :global([data-platform="mac"]) .cta-icon--apple,
  :global([data-platform="win"]) .cta-icon--windows {
    display: block;
  }

  .hero-product {
    position: relative;
    justify-self: end;
    width: min(100%, 51rem);
    perspective: 1200px;
  }

  .app-chrome {
    gap: 0.43rem;
    border: 1px solid var(--line);
    border-bottom: 0;
    background: rgba(8, 10, 15, 0.9);
    padding: 0.74rem 0.9rem;
  }

  .app-chrome span {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--fg-dim);
  }

  .app-chrome strong {
    margin-left: 0.45rem;
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  .product-screen {
    display: grid;
    grid-template-columns: 12rem minmax(0, 1fr) 12.5rem;
    min-height: 35rem;
    overflow: hidden;
    border: 1px solid var(--line);
    background: #06080c;
    box-shadow: 0 42px 110px rgba(0, 0, 0, 0.45);
  }

  .project-rail,
  .thread-stage,
  .surface-stack {
    min-width: 0;
    padding: 1rem;
  }

  .project-rail {
    display: grid;
    gap: 0.68rem;
    align-content: start;
    border-right: 1px solid var(--line);
    background: rgba(242, 238, 228, 0.025);
  }

  .rail-logo {
    color: var(--fg);
    font-size: 1.25rem;
    font-weight: 800;
  }

  .rail-search,
  .rail-item,
  .rail-section {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rail-search {
    border: 1px solid var(--line);
    color: var(--fg-dim);
    padding: 0.58rem 0.65rem;
  }

  .rail-section {
    margin-top: 0.4rem;
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
  }

  .rail-item {
    color: var(--fg-muted);
    font-size: 0.82rem;
    padding: 0.55rem 0.6rem;
  }

  .rail-item.active {
    background: rgba(80, 255, 185, 0.1);
    color: var(--fg);
  }

  .thread-stage {
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 1rem;
  }

  .thread-topline,
  .composer-strip {
    justify-content: space-between;
    gap: 0.8rem;
    border: 1px solid var(--line);
    padding: 0.72rem 0.82rem;
  }

  .thread-topline span,
  .composer-strip span {
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .thread-topline strong {
    color: var(--fg);
    font-size: 0.88rem;
  }

  .thread-topline em,
  .composer-strip strong {
    color: var(--success);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-style: normal;
    text-transform: uppercase;
  }

  .timeline {
    display: grid;
    gap: 0.74rem;
    align-content: center;
  }

  .timeline-row {
    border: 1px solid var(--line);
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    padding: 0.78rem;
    animation: timeline-breathe 4.8s ease-in-out infinite;
  }

  .timeline-row.user,
  .timeline-row.diff {
    color: var(--fg);
  }

  .timeline-row.plan {
    color: var(--review);
  }

  .timeline-row.tool {
    color: var(--accent);
  }

  .timeline-row.terminal {
    color: var(--success);
  }

  .surface-stack {
    display: grid;
    gap: 0.9rem;
    align-content: center;
    border-left: 1px solid var(--line);
  }

  .surface {
    display: grid;
    gap: 0.5rem;
    min-height: 8rem;
    align-content: end;
    border: 1px solid var(--line);
    background: rgba(242, 238, 228, 0.035);
    padding: 0.78rem;
  }

  .surface span {
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
  }

  .surface strong {
    color: var(--fg);
    font-size: 0.86rem;
    line-height: 1.2;
  }

  .surface i {
    width: 100%;
    height: 0.42rem;
    background: linear-gradient(90deg, var(--accent), rgba(242, 238, 228, 0.08));
  }

  .hero-label {
    position: absolute;
    border: 1px solid var(--line-strong);
    background: rgba(8, 10, 15, 0.88);
