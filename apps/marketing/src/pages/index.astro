---
import Layout from "../layouts/Layout.astro";
import ProviderFloat from "../components/ProviderFloat.astro";
---

<Layout
  title="ace — A workbench for coding agents"
  description="ace puts Codex, Claude, Gemini, Cursor, and other coding agents in one local workspace with project context, browser checks, review, and recovery built in."
>
  <section class="hero" aria-labelledby="hero-heading">
    <nav class="hero-nav" aria-label="Primary">
      <a href="/" class="hero-brand" aria-label="ace home">
        <img src="/logo.png" alt="" class="hero-brand-icon" />
        <span>ace</span>
      </a>
      <a
        href="https://github.com/arpan404/ace"
        target="_blank"
        rel="noopener noreferrer"
        class="hero-github"
      >
        <span>GitHub</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" class="hero-github-arrow">
          <path
            d="M5 4h7v7M12 4 4 12"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.7"
          />
        </svg>
      </a>
    </nav>

    <div class="hero-copy">
      <p class="small-line">For people who already work with coding agents</p>
      <h1 id="hero-heading">One workbench for every coding agent.</h1>
      <p class="hero-intro">
        ace keeps conversations, tools, browser checks, and code review in the same
        place, so agent work feels like one clear process instead of scattered chat tabs.
      </p>
      <div class="hero-actions" aria-label="Primary actions">
        <a id="download-btn" href="/download" class="button button-primary">
          <svg class="cta-icon cta-icon--apple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" aria-hidden="true"><path fill="currentColor" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>
          <svg class="cta-icon cta-icon--windows" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/></svg>
          <span id="download-label">Download ace</span>
        </a>
      </div>
    </div>

    <div class="hero-product" aria-label="ace product preview">
      <div class="demo-shell">
        <img
          src="/screenshot.png"
          alt="ace desktop app showing an agent thread, project sidebar, and composer"
          class="demo-image"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
      <div class="demo-notes" aria-hidden="true">
        <span>Thread view</span>
        <span>Agent tools</span>
        <span>Review loop</span>
      </div>
    </div>
  </section>

  <section class="providers" aria-labelledby="providers-heading">
    <div class="section-lede">
      <p class="small-line">Bring the subscriptions you already use</p>
      <h2 id="providers-heading">No new agent religion. Just a better desk.</h2>
      <p>
        Start with Codex, add Claude or Gemini when they fit the job, and keep every turn
        tied to the project that caused it.
      </p>
    </div>
    <ProviderFloat />
  </section>

  <section id="product" class="product-proof" aria-labelledby="product-heading">
    <div class="section-lede wide">
      <p class="small-line">Product</p>
      <h2 id="product-heading">See the agent work without switching tabs.</h2>
      <p>
        ace keeps the conversation, provider choice, file context, and browser checks in
        one local workspace.
      </p>
    </div>

    <div class="product-showcase">
      <div class="product-screenshot" data-motion-image>
        <img src="/screenshot.png" alt="ace desktop app showing an agent thread and workspace context" loading="lazy" />
      </div>

      <div class="product-points" aria-label="ace product surfaces">
        <article class="product-point">
          <span>Thread</span>
          <h3>Messages and tool output stay in one timeline.</h3>
        </article>
        <article class="product-point">
          <span>Providers</span>
          <h3>Switch models without splitting the task across chat tabs.</h3>
        </article>
        <article class="product-point">
          <span>Files</span>
          <h3>Keep the repo, changed files, and review context close to the conversation.</h3>
        </article>
        <article class="product-point">
          <span>Browser</span>
          <h3>Check UI work before the patch leaves your machine.</h3>
        </article>
      </div>
    </div>
  </section>

  <section id="workflow" class="workflow" aria-labelledby="workflow-heading">
    <div class="section-lede">
      <p class="small-line">Daily workflow</p>
      <h2 id="workflow-heading">A cleaner path from prompt to patch.</h2>
      <p>
        ace is intentionally boring about the important parts: inputs are clear,
        tool calls are visible, and reviews happen before changes get pushed.
      </p>
    </div>

    <div class="accordion-strip" aria-label="ace workflow stages">
      <article class="accordion-panel">
        <div class="workflow-preview workflow-preview-context" aria-hidden="true">
          <p>Refactor the provider picker for small screens.</p>
          <div>
            <span>ProviderModelPicker.tsx</span>
            <span>ChatView.tsx</span>
            <span>Codex / high</span>
          </div>
        </div>
        <div class="workflow-copy">
          <span>Ask</span>
          <h3>Give the agent project context</h3>
          <p>Tag files, folders, or a model. The request starts inside the repo it affects.</p>
        </div>
      </article>
      <article class="accordion-panel">
        <div class="workflow-preview workflow-preview-log" aria-hidden="true">
          <span><strong>read</strong> apps/web/src/components/chat</span>
          <span><strong>edit</strong> ProviderModelPicker.tsx</span>
          <span><strong>check</strong> astro diagnostics</span>
        </div>
        <div class="workflow-copy">
          <span>Watch</span>
          <h3>Follow real tool activity</h3>
          <p>Command output, reads, writes, and status updates stay in the thread.</p>
        </div>
      </article>
      <article class="accordion-panel">
        <div class="workflow-preview workflow-preview-review" aria-hidden="true">
          <div class="review-bars">
            <span style="--bar: 78%"></span>
            <span style="--bar: 54%"></span>
            <span style="--bar: 86%"></span>
          </div>
          <p><strong>+24</strong> added <strong>-8</strong> removed</p>
          <small>Ready for browser check</small>
        </div>
        <div class="workflow-copy">
          <span>Review</span>
          <h3>Inspect before you accept</h3>
          <p>Use browser checks, diffs, and model review to catch mistakes while the task is fresh.</p>
        </div>
      </article>
      <article class="accordion-panel">
        <div class="workflow-preview workflow-preview-resume" aria-hidden="true">
          <span>Last active 14m ago</span>
          <strong>Marketing redesign</strong>
          <p>Stopped after visual check</p>
        </div>
        <div class="workflow-copy">
          <span>Continue</span>
          <h3>Resume without rebuilding context</h3>
          <p>Sessions are treated as work in progress, not disposable chats.</p>
        </div>
      </article>
    </div>
  </section>

  <section class="stack-story" data-stack-section aria-labelledby="stack-heading">
    <div class="stack-heading">
      <p class="small-line">Built for interrupted work</p>
      <h2 id="stack-heading">The session remains readable when the work gets long.</h2>
    </div>
    <div class="stack-list">
      <article class="stack-card stack-card-one" data-stack-card>
        <p class="stack-kicker">Start</p>
        <h3>Open a project and choose the model that fits.</h3>
        <p>ace keeps provider choice explicit, with enough context for the agent to work inside the repo.</p>
      </article>
      <article class="stack-card stack-card-two" data-stack-card>
        <p class="stack-kicker">Observe</p>
        <h3>See what the agent is doing while it works.</h3>
        <p>Tool calls and partial progress are part of the interface, not hidden in a background process.</p>
      </article>
      <article class="stack-card stack-card-three" data-stack-card>
        <p class="stack-kicker">Finish</p>
        <h3>Review the patch and push with confidence.</h3>
        <p>The flow ends where engineering work actually ends: checked, reviewed, and ready to hand off.</p>
      </article>
    </div>
  </section>

  <section class="feedback" aria-labelledby="feedback-heading">
    <div class="feedback-copy">
      <p class="small-line">What the product is tuned for</p>
      <h2 id="feedback-heading">Less agent theater. More usable work.</h2>
    </div>
    <div class="feedback-panel">
      <div class="feedback-quotes" aria-live="polite">
        <blockquote class="feedback-quote is-active" data-feedback-quote>
          <p>"I need the agent, terminal output, and browser check in one place."</p>
          <cite>Context-heavy UI work</cite>
        </blockquote>
        <blockquote class="feedback-quote" data-feedback-quote>
          <p>"I want to switch models without turning a task into three separate chats."</p>
          <cite>Multi-provider coding</cite>
        </blockquote>
        <blockquote class="feedback-quote" data-feedback-quote>
          <p>"I need to come back tomorrow and know exactly where the run stopped."</p>
          <cite>Long-running sessions</cite>
        </blockquote>
      </div>
      <div class="feedback-controls" aria-label="Feedback controls">
        <button class="feedback-control is-active" type="button" data-feedback-index="0">Context</button>
        <button class="feedback-control" type="button" data-feedback-index="1">Models</button>
        <button class="feedback-control" type="button" data-feedback-index="2">Recovery</button>
      </div>
    </div>
  </section>

  <section class="final-cta" aria-labelledby="final-heading">
    <div class="final-copy">
      <h2 id="final-heading">Put your agents on one desk.</h2>
      <p>Connect the providers you already use and keep the work visible.</p>
    </div>
    <div class="final-actions">
      <a href="/download" class="button button-primary">Download ace</a>
    </div>
  </section>
</Layout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  type Platform = { os: "mac" | "win" | "linux"; label: string; arch?: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) return { os: "mac", label: "Download for macOS", arch: "arm64" };
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  async function initDownloadLink() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    if (!btn || !label) return;

    const platform = detectPlatform();
    if (!platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;
  }

  function initMotion() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo(
      gsap.utils.toArray<HTMLElement>(".hero-nav, .hero-copy > *, .hero-product"),
      { y: 22, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.82,
        ease: "power3.out",
        stagger: 0.08,
      },
    );

    gsap.utils
      .toArray<HTMLElement>(
        ".section-lede, .product-point, .accordion-panel, .stack-heading, .feedback-copy, .feedback-panel, .final-cta",
      )
      .forEach((element) => {
        gsap.fromTo(
          element,
          { y: 34, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.78,
            ease: "power3.out",
            scrollTrigger: {
              trigger: element,
              start: "top 86%",
              once: true,
            },
          },
        );
      });

    gsap.utils.toArray<HTMLElement>("[data-motion-image]").forEach((element) => {
      gsap.fromTo(
        element,
        { scale: 0.88, opacity: 0.58 },
        {
          scale: 1,
          opacity: 1,
          ease: "none",
          scrollTrigger: {
            trigger: element,
            start: "top 88%",
            end: "bottom 30%",
            scrub: true,
          },
        },
      );
    });

    gsap.utils.toArray<HTMLElement>("[data-stack-card]").forEach((card) => {
      gsap.fromTo(
        card,
        { y: 74, opacity: 0.58, scale: 0.96 },
        {
          y: 0,
          opacity: 1,
          scale: 1,
          ease: "none",
          scrollTrigger: {
            trigger: card,
            start: "top 92%",
            end: "top 44%",
            scrub: true,
          },
        },
      );
    });
  }

  function initFeedback() {
    const quotes = Array.from(document.querySelectorAll<HTMLElement>("[data-feedback-quote]"));
    const controls = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-feedback-index]"));
    if (quotes.length === 0 || controls.length === 0) return;

    controls.forEach((control) => {
      control.addEventListener("click", () => {
        const activeIndex = Number(control.dataset.feedbackIndex ?? 0);
        quotes.forEach((quote, index) => quote.classList.toggle("is-active", index === activeIndex));
        controls.forEach((item, index) => item.classList.toggle("is-active", index === activeIndex));
      });
    });
  }

  initDownloadLink();
  initMotion();
  initFeedback();
</script>

<style>
  .hero,
  .providers,
  .product-proof,
  .workflow,
  .stack-story,
  .feedback,
  .final-cta {
    width: min(100% - 2rem, 1180px);
    margin: 0 auto;
  }

  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(28rem, 1fr);
    grid-template-rows: auto minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: center;
    min-height: 100dvh;
    padding: clamp(1.15rem, 2.5vw, 1.8rem) 0 clamp(6rem, 9vw, 9rem);
  }

  .hero-nav {
    grid-column: 1 / -1;
    justify-self: stretch;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    margin-bottom: clamp(1rem, 4vw, 3rem);
  }

  .hero-brand,
  .hero-github {
    display: inline-flex;
    align-items: center;
    color: var(--fg);
    font-weight: 800;
    letter-spacing: 0;
  }

  .hero-brand {
    gap: 0.65rem;
    min-width: 0;
  }

  .hero-brand-icon {
    width: 34px;
    height: 34px;
    border-radius: 7px;
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.28);
  }

  .hero-github {
    gap: 0.35rem;
    color: var(--fg-muted);
    font-size: 0.94rem;
    transition:
      color 220ms ease,
      transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-github-arrow {
    width: 0.9rem;
    height: 0.9rem;
    transition: transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-github:hover {
    color: var(--fg);
    transform: translateY(-1px);
  }

  .hero-github:hover .hero-github-arrow {
    transform: translate(2px, -2px);
  }

  .hero-copy {
    display: grid;
    max-width: 40rem;
    gap: 1.55rem;
  }

  .small-line {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero h1 {
    max-width: min(100%, 11ch);
    color: var(--fg);
    font-size: clamp(3.4rem, 7vw, 7.2rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.88;
    text-wrap: balance;
  }

  .hero-intro {
    max-width: 36rem;
    color: var(--fg-muted);
    font-size: clamp(1.12rem, 2vw, 1.32rem);
    line-height: 1.55;
  }

  .hero-actions,
  .final-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
  }

  .button {
    display: inline-flex;
    min-height: 3.1rem;
    align-items: center;
    justify-content: center;
    gap: 0.68rem;
    border-radius: 999px;
    padding: 0.84rem 1.25rem;
    font-weight: 800;
    line-height: 1;
    transition:
      background 240ms ease,
      color 240ms ease,
      transform 240ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 240ms ease;
    will-change: transform;
  }

  .button:hover {
    transform: translateY(-2px) scale(1.01);
  }

  .button:active {
    transform: translateY(1px) scale(0.99);
  }

  .button-primary {
    background: var(--surface-strong);
    color: var(--ink);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.22);
  }

  .cta-icon {
    display: none;
    width: 1.05rem;
    height: 1.05rem;
  }

  :global([data-platform="mac"]) .cta-icon--apple,
  :global([data-platform="win"]) .cta-icon--windows {
    display: block;
  }

  .hero-product {
    position: relative;
    width: min(100%, 42rem);
    min-width: 0;
    justify-self: end;
  }

  .demo-shell {
    position: relative;
    border: 1px solid rgba(246, 240, 230, 0.16);
    border-radius: 18px;
    background:
      linear-gradient(180deg, rgba(255, 249, 235, 0.08), transparent 28%),
      rgba(246, 240, 230, 0.035);
    padding: 0.75rem;
    box-shadow:
      0 34px 90px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(246, 240, 230, 0.08);
    transform: rotate(-0.65deg);
    transition:
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 280ms ease,
      box-shadow 700ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  .demo-shell:hover {
    border-color: rgba(246, 240, 230, 0.26);
    box-shadow:
      0 42px 100px rgba(0, 0, 0, 0.52),
      0 0 52px oklch(0.68 0.18 255 / 0.12),
      inset 0 1px 0 rgba(246, 240, 230, 0.1);
    transform: rotate(-0.2deg) translate3d(0, -4px, 0);
  }

  .demo-image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: 12px;
    object-fit: cover;
    object-position: 50% 0%;
    box-shadow: inset 0 0 0 1px rgba(246, 240, 230, 0.08);
  }

  .demo-notes {
    position: absolute;
    right: -0.5rem;
    bottom: -2.2rem;
    display: flex;
    gap: 0.45rem;
    align-items: center;
    border: 1px solid rgba(16, 16, 14, 0.08);
    border-radius: 999px;
    background: var(--surface-strong);
    color: var(--ink);
    padding: 0.48rem;
    box-shadow: 0 18px 38px rgba(0, 0, 0, 0.26);
  }

  .demo-notes span {
    border-radius: 999px;
    background: rgba(16, 16, 14, 0.07);
    padding: 0.45rem 0.6rem;
    font-size: 0.78rem;
    font-weight: 800;
    white-space: nowrap;
    transition:
      background 220ms ease,
      transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-product:hover .demo-notes span {
    background: rgba(16, 16, 14, 0.11);
    transform: translateY(-1px);
  }

  .providers,
  .product-proof,
  .workflow,
  .stack-story,
  .feedback {
    padding: clamp(6rem, 12vw, 11rem) 0;
  }

  .section-lede {
    display: grid;
    gap: 0.9rem;
    max-width: 46rem;
    margin-bottom: clamp(2rem, 4vw, 3.8rem);
  }

  .section-lede.wide {
    max-width: 62rem;
  }

  .section-lede h2,
  .stack-heading h2,
  .feedback-copy h2,
  .final-copy h2 {
    color: var(--fg);
    font-size: clamp(2.45rem, 5vw, 5rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.94;
    text-wrap: balance;
  }

  .section-lede p:not(.small-line),
  .workflow .section-lede p:not(.small-line),
  .final-copy p {
    max-width: 42rem;
    color: var(--fg-muted);
    font-size: 1.1rem;
    line-height: 1.65;
  }

  .product-showcase {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
    gap: clamp(1.25rem, 3vw, 2rem);
    align-items: stretch;
  }

  .product-screenshot {
    overflow: hidden;
    border: 1px solid rgba(246, 240, 230, 0.13);
    border-radius: var(--radius);
    background:
      linear-gradient(180deg, rgba(246, 240, 230, 0.08), transparent 28%),
      rgba(246, 240, 230, 0.04);
    padding: 0.75rem;
    transform-origin: center;
    box-shadow: 0 28px 64px rgba(0, 0, 0, 0.34);
    transition:
      border-color 260ms ease,
      box-shadow 460ms ease;
  }

  .product-screenshot:hover {
    border-color: rgba(246, 240, 230, 0.24);
    box-shadow:
      0 34px 78px rgba(0, 0, 0, 0.42),
      0 0 54px oklch(0.68 0.18 255 / 0.1);
  }

  .product-screenshot img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: 6px;
    object-fit: cover;
    object-position: 50% 0%;
    opacity: 0.94;
    filter: contrast(1.08) saturate(0.88);
    transition: transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-screenshot:hover img {
    transform: scale(1.04);
  }

  .product-points {
    display: grid;
    border-top: 1px solid rgba(246, 240, 230, 0.15);
  }

  .product-point {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    border-bottom: 1px solid rgba(246, 240, 230, 0.15);
    padding: clamp(1rem, 2vw, 1.25rem) 0;
    transition:
      border-color 220ms ease,
      transform 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-point:hover {
    border-color: rgba(246, 240, 230, 0.28);
    transform: translateX(4px);
  }

  .product-point span {
    color: var(--accent);
