---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="ace - Coding agent workspace"
  description="ace is a desktop workspace for running coding agents with project threads, provider sessions, terminal context, browser checks, editor review, GitHub workflows, and recovery in one place."
>
  <nav class="site-nav" aria-label="Primary">
    <a href="/" class="brand" aria-label="ace home">
      <img src="/logo.png" alt="" class="brand-icon" />
      <span>ace</span>
    </a>
    <div class="nav-links">
      <a href="#workspace">Workspace</a>
      <a href="#product">Product</a>
      <a href="#reliability">Reliability</a>
      <a href="/changelog">Changelog</a>
      <a href="https://github.com/arpan404/ace" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </nav>

  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-copy" data-reveal>
      <p class="eyebrow">Desktop app for coding agents</p>
      <h1 id="hero-heading">ace</h1>
      <p class="hero-intro">
        Run Codex, Claude, Gemini, Cursor, GitHub Copilot, and OpenCode from one workspace built
        around real project threads, local context, review surfaces, and recovery.
      </p>
      <div class="hero-actions" aria-label="Primary actions">
        <a id="download-btn" href="/download" class="button button-primary" data-interactive>
          <svg
            class="cta-icon cta-icon--apple"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 814 1000"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"
            />
          </svg>
          <svg
            class="cta-icon cta-icon--windows"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 88 88"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"
            />
          </svg>
          <span class="cta-icon cta-icon--linux" aria-hidden="true">Lx</span>
          <span id="download-label">Download ace</span>
        </a>
        <a href="#workspace" class="button button-secondary" data-interactive>See product flow</a>
      </div>
    </div>

    <figure class="product-shot" data-reveal data-interactive>
      <img
        src="/screenshot.png"
        alt="ace desktop workspace showing project threads, a coding agent conversation, and review panels"
        width="3456"
        height="2168"
        loading="eager"
        decoding="async"
      />
      <figcaption>Project threads, agent timeline, terminal context, and review panels stay together.</figcaption>
    </figure>
  </section>

  <section class="facts" aria-label="Product facts">
    <div data-reveal>
      <span>Providers</span>
      <strong>Codex, Claude, Gemini, Cursor, Copilot, OpenCode</strong>
    </div>
    <div data-reveal>
      <span>Runtime</span>
      <strong>Local sessions over desktop and WebSocket hosts</strong>
    </div>
    <div data-reveal>
      <span>Review</span>
      <strong>Terminal, browser, editor, diffs, GitHub handoff</strong>
    </div>
  </section>

  <section id="workspace" class="workspace" aria-labelledby="workspace-heading">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Workspace</p>
      <h2 id="workspace-heading">A coding-agent run has more state than a chat can hold.</h2>
      <p>
        ace keeps the repository, thread history, provider runtime, pending approvals, tool output,
        browser checks, and review context attached to the same piece of work.
      </p>
    </div>

    <div class="product-grid">
      <article data-reveal data-interactive>
        <span>01</span>
        <h3>Start from the project</h3>
        <p>
          Threads are organized by repository, branch, provider, model, worktree, and status so long
          running work remains findable.
        </p>
      </article>
      <article data-reveal data-interactive>
        <span>02</span>
        <h3>Keep the runtime visible</h3>
        <p>
          Plans, approvals, tool calls, queued steering, user input, and provider errors are shown as
          product events instead of disappearing into a transcript.
        </p>
      </article>
      <article data-reveal data-interactive>
        <span>03</span>
        <h3>Review in place</h3>
        <p>
          Terminal output, browser tabs, workspace files, changed-file trees, and diffs sit beside
          the conversation when they matter.
        </p>
      </article>
    </div>
  </section>

  <section id="product" class="product-section" aria-labelledby="product-heading">
    <div class="section-head compact" data-reveal>
      <p class="eyebrow">Product surfaces</p>
      <h2 id="product-heading">The app is the interface.</h2>
    </div>

    <div class="surface-list">
      <article class="surface-row" data-reveal data-interactive>
        <div>
          <span>Thread board</span>
          <h3>Project work is grouped before you prompt.</h3>
        </div>
        <p>
          Recent threads, archived work, project search, runtime status, branch context, and provider
          choices are reachable before a new turn starts.
        </p>
      </article>
      <article class="surface-row" data-reveal data-interactive>
        <div>
          <span>Conversation timeline</span>
          <h3>Agent activity stays inspectable.</h3>
        </div>
        <p>
          Streaming provider output is projected into durable events so reconnects, restarts, and
          partial streams do not erase what happened.
        </p>
      </article>
      <article class="surface-row" data-reveal data-interactive>
        <div>
          <span>Review stack</span>
          <h3>Browser, terminal, editor, and diff panes share context.</h3>
        </div>
        <p>
          Verification work is part of the thread: run scripts, inspect local UI, review files, and
          pass exact context back to the agent.
        </p>
      </article>
      <article class="surface-row" data-reveal data-interactive>
        <div>
          <span>Remote control</span>
          <h3>Desktop-first, with remote and mobile access.</h3>
        </div>
        <p>
          Pair remote hosts, switch projects, monitor agent counts, and resume work without moving the
          local provider runtime into the browser.
        </p>
      </article>
    </div>
  </section>

  <section class="screenshot-band" aria-label="ace product screenshot" data-reveal data-interactive>
    <img
      src="/screenshot.png"
      alt="ace product interface with sidebar, conversation, composer, and workspace panels"
      width="3456"
      height="2168"
      loading="lazy"
      decoding="async"
    />
  </section>

  <section id="reliability" class="reliability" aria-labelledby="reliability-heading">
    <div class="section-head compact" data-reveal>
      <p class="eyebrow">Reliability</p>
      <h2 id="reliability-heading">Built for long runs and interrupted state.</h2>
      <p>
        ace treats failures as part of the product surface: stale sessions, provider restarts,
        approvals, checkpoint restore, and reconnect behavior are designed into the workflow.
      </p>
    </div>

    <div class="reliability-table" role="table" aria-label="Reliability capabilities">
      <div role="row" data-reveal data-interactive>
        <span role="cell">Provider sessions</span>
        <strong role="cell">Startup, resume, restart, handoff, and runtime event logging</strong>
      </div>
      <div role="row" data-reveal data-interactive>
        <span role="cell">Thread recovery</span>
        <strong role="cell">Checkpoints, transcript rebuilds, snapshots, and archived history</strong>
      </div>
      <div role="row" data-reveal data-interactive>
        <span role="cell">User attention</span>
        <strong role="cell">Pending approvals, input requests, notifications, and queued steering</strong>
      </div>
      <div role="row" data-reveal data-interactive>
        <span role="cell">Local context</span>
        <strong role="cell">Terminal state, browser state, workspace files, branches, and PR context</strong>
      </div>
    </div>
  </section>

  <section class="final-cta" aria-labelledby="final-heading">
    <div data-reveal>
      <p class="eyebrow">Download</p>
      <h2 id="final-heading">Put agent work in a workspace you can inspect.</h2>
    </div>
    <a href="/download" class="button button-primary" data-reveal data-interactive>Download ace</a>
  </section>
</Layout>

<script>
  type Platform = { os: "mac" | "win" | "linux"; label: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) return { os: "mac", label: "Download for macOS" };
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
  const label = document.getElementById("download-label");
  const platform = detectPlatform();

  if (btn && label && platform) {
    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;
  }
</script>

<style>
  .site-nav,
  .hero,
  .facts,
  .workspace,
  .product-section,
  .screenshot-band,
  .reliability,
  .final-cta {
    width: min(100% - 2rem, 1240px);
    margin: 0 auto;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.5rem;
    border-bottom: 1px solid var(--line);
  }

  .brand,
  .nav-links,
  .hero-actions,
  .button {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 0.65rem;
    color: var(--fg);
    font-weight: 800;
  }

  .brand-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 7px;
  }

  .nav-links {
    gap: 1.4rem;
    color: var(--fg-muted);
    font-size: 0.9rem;
    font-weight: 650;
  }

  .nav-links a {
    position: relative;
    transition: color 150ms ease;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -0.35rem;
    left: 0;
    height: 1px;
    background: currentColor;
    opacity: 0;
    transform: scaleX(0.5);
    transition:
      opacity 150ms ease,
      transform 180ms ease;
  }

  .nav-links a:hover {
    color: var(--fg);
  }

  .nav-links a:hover::after,
  .nav-links a:focus-visible::after {
    opacity: 0.55;
    transform: scaleX(1);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(18rem, 0.54fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: center;
    min-height: min(42rem, calc(100svh - 4.5rem));
    padding: 2rem 0 1.75rem;
  }

  .hero-copy,
  .section-head,
  .final-cta > div {
    display: grid;
    gap: 1rem;
  }

  .hero-copy {
    align-content: center;
  }

  .eyebrow {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    text-wrap: balance;
  }

  .hero h1 {
    color: var(--fg);
    font-size: 8.8rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.82;
  }

  .hero-intro,
  .section-head p,
  .product-grid p,
  .surface-row p,
  .product-shot figcaption {
    color: var(--fg-muted);
    font-size: 1.06rem;
    line-height: 1.62;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 0.35rem;
  }

  .button {
    min-height: 2.85rem;
    justify-content: center;
    gap: 0.58rem;
    border: 1px solid transparent;
    border-radius: 7px;
    padding: 0.78rem 1rem;
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1;
    transition:
      transform 150ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 150ms ease,
      background 150ms ease,
      box-shadow 150ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button-primary {
    background: var(--fg);
    color: var(--ink);
    box-shadow: 0 0 0 rgba(244, 241, 232, 0);
  }

  .button-primary:hover {
    box-shadow: 0 16px 38px rgba(244, 241, 232, 0.12);
  }

  .button-secondary {
    border-color: var(--line-strong);
    background: rgba(244, 241, 232, 0.045);
    color: var(--fg);
  }

  .button-secondary:hover {
    border-color: rgba(244, 241, 232, 0.42);
    background: rgba(244, 241, 232, 0.075);
  }

  .cta-icon {
    display: none;
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
  }

  .cta-icon--linux {
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 800;
    line-height: 1;
  }

  :global([data-platform="mac"]) .cta-icon--apple,
  :global([data-platform="win"]) .cta-icon--windows {
    display: block;
  }

  :global([data-platform="linux"]) .cta-icon--linux {
    display: inline-grid;
  }

  .product-shot {
    display: grid;
    gap: 0.85rem;
    min-width: 0;
    margin: 0;
    transform-origin: center;
    perspective: 1200px;
    transition:
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 220ms ease;
  }

  .macbook-frame {
    display: grid;
    gap: 0;
    width: 100%;
    max-height: min(34rem, calc(100svh - 11.5rem));
    transform: rotateX(1.4deg) rotateY(-2.4deg) translateZ(0);
    transform-style: preserve-3d;
    filter: drop-shadow(0 34px 48px rgba(0, 0, 0, 0.34));
    transition:
      filter 260ms ease,
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .macbook-screen {
    position: relative;
    overflow: hidden;
    padding: 0.54rem 0.54rem 0.66rem;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 18px 18px 8px 8px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.18), transparent 10%),
      linear-gradient(180deg, #30343a 0%, #1d2026 11%, #08090c 12%, #07080a 100%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      inset 0 -10px 18px rgba(0, 0, 0, 0.34),
      0 22px 58px rgba(0, 0, 0, 0.38);
    transform: translateZ(18px);
  }

  .macbook-screen::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(112deg, rgba(255, 255, 255, 0.12), transparent 17%, transparent 72%),
      linear-gradient(180deg, transparent 74%, rgba(0, 0, 0, 0.28));
    opacity: 0.14;
  }

  .macbook-screen::before {
    content: "";
    position: absolute;
    inset: 0.54rem 0.54rem 0.66rem;
    z-index: 1;
    pointer-events: none;
    border-radius: 10px 10px 4px 4px;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.045),
      inset 0 0 28px rgba(0, 0, 0, 0.32);
  }

  .macbook-camera {
    position: absolute;
    top: 0.2rem;
    left: 50%;
    z-index: 3;
    width: 0.32rem;
    height: 0.32rem;
    border-radius: 999px;
    background: #050607;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.12),
      inset 0 0 0 1px rgba(138, 209, 255, 0.22);
    transform: translateX(-50%);
  }

  .macbook-screen img {
    display: block;
    width: 100%;
    height: auto;
    max-height: min(30rem, calc(100svh - 15rem));
    object-fit: contain;
    border-radius: 8px 8px 3px 3px;
    transform: translateZ(2px);
  }

  .macbook-base {
    position: relative;
    height: 1.18rem;
    margin-top: -0.02rem;
    margin-inline: 2.8%;
    border-radius: 0 0 18px 18px;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.16), rgba(255, 255, 255, 0.34) 18%, rgba(255, 255, 255, 0.16) 50%, rgba(255, 255, 255, 0.34) 82%, rgba(0, 0, 0, 0.2)),
      linear-gradient(180deg, #d7d9dc 0%, #aeb3b9 38%, #747b84 70%, #3c4149 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.65),
      inset 0 -5px 10px rgba(0, 0, 0, 0.26),
      0 18px 30px rgba(0, 0, 0, 0.28);
    clip-path: polygon(7% 0, 93% 0, 100% 100%, 0 100%);
    transform: rotateX(-8deg) translateZ(2px);
    transform-origin: top center;
  }

  .macbook-base::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    width: 17%;
    height: 0.34rem;
    border-radius: 0 0 999px 999px;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.2), rgba(255, 255, 255, 0.12)),
      rgba(0, 0, 0, 0.1);
    box-shadow: inset 0 -1px 0 rgba(255, 255, 255, 0.3);
    transform: translateX(-50%);
  }

  .macbook-base::after {
    content: "";
    position: absolute;
    top: -0.12rem;
    right: 5%;
    left: 5%;
    height: 0.16rem;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
    opacity: 0.7;
  }

  .macbook-base span {
    position: absolute;
    right: 4%;
    bottom: -0.24rem;
    left: 4%;
    height: 0.26rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.32);
    filter: blur(5px);
  }

  .screenshot-band img {
    width: 100%;
    height: auto;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.32);
    transition:
      border-color 180ms ease,
      box-shadow 220ms ease,
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .product-shot:hover .macbook-screen,
  .product-shot:focus-visible .macbook-screen {
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      inset 0 -10px 18px rgba(0, 0, 0, 0.3),
      0 34px 96px rgba(0, 0, 0, 0.44);
    transform: translateY(-3px);
  }

  .product-shot:hover .macbook-frame,
  .product-shot:focus-visible .macbook-frame {
    filter: drop-shadow(0 48px 58px rgba(0, 0, 0, 0.34));
    transform: rotateX(1deg) rotateY(-1.5deg) translate3d(0, -2px, 0);
  }

  .macbook-screen {
    transition:
      box-shadow 220ms ease,
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .product-shot figcaption {
    max-width: 46rem;
    color: var(--fg-dim);
    font-size: 0.88rem;
  }

  .facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .facts div {
    display: grid;
    gap: 0.35rem;
    min-height: 7rem;
    align-content: center;
    padding: 1rem 1.1rem;
    transition:
      background 180ms ease,
      transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .facts div:hover {
    background: rgba(244, 241, 232, 0.035);
    transform: translateY(-1px);
  }

  .facts div + div {
    border-left: 1px solid var(--line);
  }

  .facts span,
  .product-grid span,
  .surface-row span,
  .reliability-table span {
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  .facts strong,
  .reliability-table strong {
    color: var(--fg);
    font-size: 1.12rem;
    line-height: 1.25;
  }

  .workspace,
  .product-section,
  .reliability {
    padding: clamp(4rem, 8vw, 7rem) 0;
  }

  .section-head {
    max-width: 56rem;
    margin-bottom: 3rem;
  }

  .section-head.compact {
    max-width: 48rem;
  }

  .section-head h2,
  .final-cta h2 {
    color: var(--fg);
    font-size: 4.8rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.94;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border: 1px solid var(--line);
  }

  .product-grid article {
    display: grid;
    gap: 1rem;
    min-height: 21rem;
    align-content: end;
    padding: clamp(1rem, 2.4vw, 1.5rem);
    background: rgba(244, 241, 232, 0.028);
    transition:
      background 180ms ease,
      border-color 180ms ease,
      transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .product-grid article:hover {
    background: rgba(244, 241, 232, 0.048);
    transform: translateY(-3px);
  }

  .product-grid article + article {
    border-left: 1px solid var(--line);
  }

  .product-grid h3,
  .surface-row h3 {
    color: var(--fg);
    font-size: clamp(1.35rem, 2rem, 2rem);
    font-weight: 800;
    line-height: 1;
  }

  .surface-list {
    border-top: 1px solid var(--line);
  }

  .surface-row {
    display: grid;
    grid-template-columns: minmax(16rem, 0.64fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: start;
    border-bottom: 1px solid var(--line);
    padding: clamp(1.25rem, 3.5vw, 2.2rem) 0;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      padding-inline 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .surface-row:hover {
