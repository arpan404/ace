---
import Layout from "../layouts/Layout.astro";
import ProviderIcon from "../components/ProviderIcon.astro";

const providers = [
  { label: "Codex", kind: "codex" },
  { label: "Gemini", kind: "gemini" },
  { label: "Claude", kind: "claude" },
  { label: "Cursor", kind: "cursor" },
  { label: "GitHub Copilot", kind: "githubCopilot" },
  { label: "OpenCode", kind: "opencode" },
] as const;

const workspaceFeatures = [
  {
    label: "Browser",
    title: "Built-in browser with design mode.",
    text: "Open the local app beside the agent thread, inspect UI changes, and leave visual feedback without jumping between tools.",
  },
  {
    label: "Editor",
    title: "In-app code editor for review.",
    text: "Inspect files, changed paths, and implementation context next to the conversation before you approve, steer, or hand off work.",
  },
  {
    label: "Background work",
    title: "Notifications when agents finish.",
    text: "Let long turns run in the background and get attention prompts when an agent completes, needs approval, or asks for input.",
  },
  {
    label: "Performance",
    title: "Built for heavy agent sessions.",
    text: "ace is designed around large histories, partial streams, reconnects, and dense local context without turning the UI into a bottleneck.",
  },
] as const;

const remoteFeatures = [
  {
    label: "Remote host",
    title: "Host ace on a remote server.",
    text: "Run the daemon on a workstation or server, then use the UI from another device while the agents keep working near the repo.",
  },
  {
    label: "Many hosts",
    title: "Connect as many hosts as you need.",
    text: "Switch between machines, projects, and local runtimes instead of forcing every repo through one browser tab or one desktop.",
  },
  {
    label: "No GUI required",
    title: "Install the daemon, use the UI elsewhere.",
    text: "Prefer a headless setup? Run the host process where the code lives and connect from the device you actually want to use.",
  },
  {
    label: "Mobile",
    title: "Remote access on mobile.",
    text: "Mobile access is coming soon, so you can monitor runs, respond to prompts, and keep work moving away from the desk.",
    badge: "Coming soon",
  },
] as const;

const roadmapFeatures = [
  {
    label: "Flow Mode",
    title: "Multi-agent flows across providers.",
    text: "Set up loops where Codex finishes backend work, Gemini picks up the web UI, Claude handles mobile, Cursor writes tests, and OpenCode coordinates the run.",
    badge: "Coming soon",
  },
  {
    label: "Skills",
    title: "Skills management for agent workflows.",
    text: "Manage reusable instructions, workflows, and capability packs so teams can standardize how agents work across projects.",
    badge: "Coming soon",
  },
] as const;
---

<Layout
  title="ace - Coding agent workspace"
  description="ace is a desktop workspace for running coding agents with project threads, provider sessions, terminal context, browser checks, editor review, GitHub workflows, and recovery in one place."
>
  <nav class="site-nav" aria-label="Primary">
    <a href="/" class="brand" aria-label="ace home">
      <img src="/logo.png" alt="" class="brand-icon" />
      <span>ace</span>
    </a>
    <div class="nav-links">
      <a href="#workspace">Workspace</a>
      <a href="#providers">Providers</a>
      <a href="#remote">Remote</a>
      <a href="#roadmap">Roadmap</a>
      <a href="/changelog">Changelog</a>
      <a href="https://github.com/arpan404/ace" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </nav>

  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-copy" data-reveal>
      <p class="eyebrow">Desktop app for coding agents</p>
      <h1 id="hero-heading">ace</h1>
      <p class="hero-intro">
        Run Codex, Claude, Gemini, Cursor, GitHub Copilot, and OpenCode from one workspace built
        around real project threads, local context, review surfaces, and recovery.
      </p>
      <div class="hero-chips" aria-label="Product highlights">
        <span>Local runtimes</span>
        <span>Project threads</span>
        <span>Recoverable runs</span>
      </div>
      <div class="hero-actions" aria-label="Primary actions">
        <a id="download-btn" href="/download" class="button button-primary" data-interactive>
          <svg
            class="cta-icon cta-icon--apple"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 814 1000"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"
            />
          </svg>
          <svg
            class="cta-icon cta-icon--windows"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 88 88"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"
            />
          </svg>
          <span class="cta-icon cta-icon--linux" aria-hidden="true">Lx</span>
          <span id="download-label">Download ace</span>
        </a>
        <a href="#workspace" class="button button-secondary" data-interactive>See product flow</a>
      </div>
    </div>

    <figure class="product-shot" data-reveal data-interactive>
      <div class="product-window" data-scroll-3d data-scroll-strength="1.08">
        <div class="product-window-bar" aria-hidden="true">
          <span class="window-controls"><i></i><i></i><i></i></span>
          <span class="window-title">ace / project thread</span>
          <span class="window-status">live workspace</span>
        </div>
        <img
          src="/screenshot.png"
          alt="ace desktop workspace showing project threads, a coding agent conversation, and review panels"
          width="3456"
          height="2168"
          loading="eager"
          decoding="async"
        />
      </div>
      <figcaption>Project threads, agent timeline, terminal context, and review panels stay together.</figcaption>
    </figure>
  </section>

  <section class="facts" aria-label="Product facts" data-scroll-3d data-scroll-strength="0.45">
    <div data-reveal>
      <span>Providers</span>
      <strong>Codex, Claude, Gemini, Cursor, Copilot, OpenCode</strong>
    </div>
    <div data-reveal>
      <span>Runtime</span>
      <strong>Local sessions over desktop and WebSocket hosts</strong>
    </div>
    <div data-reveal>
      <span>Review</span>
      <strong>Terminal, browser, editor, diffs, GitHub handoff</strong>
    </div>
  </section>

  <section id="workspace" class="workspace feature-band" aria-labelledby="workspace-heading">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Workspace</p>
      <h2 id="workspace-heading">Everything needed to supervise agent work.</h2>
      <p>
        A coding-agent run is not just a chat. It needs browser checks, code review, background
        notifications, and enough performance headroom for long-running local work.
      </p>
    </div>

    <div class="feature-grid" data-scroll-3d data-scroll-strength="0.55">
      {workspaceFeatures.map((feature, index) => (
        <article class:list={["feature-card", index === 0 ? "feature-card--wide" : ""]} data-reveal data-interactive>
          <div class="feature-card-visual" aria-hidden="true">
            <img src="/screenshot.png" alt="" loading="lazy" decoding="async" />
          </div>
          <div class="feature-card-copy">
            <span>{feature.label}</span>
            <h3>{feature.title}</h3>
            <p>{feature.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="providers" class="provider-section feature-band" aria-labelledby="providers-heading">
    <div class="section-head compact" data-reveal>
      <p class="eyebrow">Provider handoff</p>
      <h2 id="providers-heading">Switch agents without losing the thread.</h2>
      <p>
        Work can move between providers while the project, conversation, terminal context, browser
        checks, and review state stay attached to the same run. Bring your own subscriptions: use
        whichever provider accounts, CLIs, and paid plans you already trust.
      </p>
    </div>

    <div class="provider-story" data-scroll-3d data-scroll-strength="0.5">
      <div class="provider-logo-grid" aria-label="Supported providers">
        {providers.map((provider) => (
          <div class="provider-logo-card" data-reveal data-interactive>
            <ProviderIcon kind={provider.kind} />
            <span>{provider.label}</span>
          </div>
        ))}
      </div>
      <article class="provider-copy" data-reveal data-interactive>
        <span>Bring your own subscription</span>
        <h3>Hand off a run to the agent that fits the next job.</h3>
        <p>
          ace does not force one model choice. Connect the provider accounts you already pay for,
          switch when another agent is stronger, and keep the same project history instead of
          rebuilding context in a new chat.
        </p>
        <div class="handoff-line" aria-hidden="true">
          {providers.slice(0, 5).map((provider) => (
            <span><ProviderIcon kind={provider.kind} /></span>
          ))}
        </div>
      </article>
    </div>
  </section>

  <section id="remote" class="remote-section feature-band" aria-labelledby="remote-heading">
    <div class="section-head compact" data-reveal>
      <p class="eyebrow">Remote access</p>
      <h2 id="remote-heading">Run agents where the code lives. Use ace where you are.</h2>
      <p>
        Host ace on a local workstation or remote server, connect from another device, and keep
        multiple hosts available for different projects and machines.
      </p>
    </div>

    <div class="feature-grid feature-grid--remote" data-scroll-3d data-scroll-strength="0.48">
      {remoteFeatures.map((feature) => (
        <article class="feature-card feature-card--compact" data-reveal data-interactive>
          <div class="feature-card-copy">
            <span>{feature.label}</span>
            <h3>{feature.title}</h3>
            <p>{feature.text}</p>
            {"badge" in feature ? <em>{feature.badge}</em> : null}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="roadmap" class="roadmap-section feature-band" aria-labelledby="roadmap-heading">
    <div class="section-head compact" data-reveal>
      <p class="eyebrow">Roadmap</p>
      <h2 id="roadmap-heading">Next: persistent multi-agent workflows.</h2>
      <p>
        ace is moving toward cross-provider, multi-agent flows where providers can pass work between
        each other and keep running as a coordinated loop.
      </p>
    </div>

    <div class="roadmap-grid" data-scroll-3d data-scroll-strength="0.48">
      {roadmapFeatures.map((feature) => (
        <article class="roadmap-card" data-reveal data-interactive>
          <span>{feature.label}</span>
          <h3>{feature.title}</h3>
          <p>{feature.text}</p>
          <em>{feature.badge}</em>
        </article>
      ))}
    </div>
  </section>

  <section class="final-cta" aria-labelledby="final-heading" data-scroll-3d data-scroll-strength="0.48">
    <div data-reveal>
      <p class="eyebrow">Download</p>
      <h2 id="final-heading">Put agent work in a workspace you can inspect.</h2>
    </div>
    <a href="/download" class="button button-primary" data-reveal data-interactive>Download ace</a>
  </section>
</Layout>

<script>
  type Platform = { os: "mac" | "win" | "linux"; label: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) return { os: "mac", label: "Download for macOS" };
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
  const label = document.getElementById("download-label");
  const platform = detectPlatform();

  if (btn && label && platform) {
    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;
  }
</script>

<style>
  .site-nav,
  .hero,
  .facts,
  .workspace,
  .feature-band,
  .final-cta {
    width: min(100% - 2rem, 1240px);
    margin: 0 auto;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.5rem;
    border-bottom: 1px solid var(--line);
  }

  .brand,
  .nav-links,
  .hero-actions,
  .button {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 0.65rem;
    color: var(--fg);
    font-weight: 800;
  }

  .brand-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 7px;
  }

  .nav-links {
    gap: 1.4rem;
    color: var(--fg-muted);
    font-size: 0.9rem;
    font-weight: 650;
  }

  .nav-links a {
    position: relative;
    transition: color 150ms ease;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -0.35rem;
    left: 0;
    height: 1px;
    background: currentColor;
    opacity: 0;
    transform: scaleX(0.5);
    transition:
      opacity 150ms ease,
      transform 180ms ease;
  }

  .nav-links a:hover {
    color: var(--fg);
  }

  .nav-links a:hover::after,
  .nav-links a:focus-visible::after {
    opacity: 0.55;
    transform: scaleX(1);
  }

  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(18rem, 0.54fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: center;
    min-height: min(42rem, calc(100svh - 4.5rem));
    padding: 2rem 0 1.75rem;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 8% -3% auto auto;
    z-index: -1;
    width: min(38rem, 48vw);
    height: min(27rem, 54vh);
    border: 1px solid rgba(138, 209, 255, 0.16);
    background:
      linear-gradient(rgba(244, 241, 232, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(244, 241, 232, 0.035) 1px, transparent 1px),
      linear-gradient(135deg, rgba(138, 209, 255, 0.1), transparent 56%);
    background-size: 32px 32px, 32px 32px, auto;
    opacity: 0.58;
    mask-image: linear-gradient(120deg, black, transparent 82%);
  }

  .hero-copy,
  .section-head,
  .final-cta > div {
    display: grid;
    gap: 1rem;
  }

  .hero-copy {
    align-content: center;
  }

  .eyebrow {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    text-wrap: balance;
  }

  .hero h1 {
    color: var(--fg);
    font-size: 8.8rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.82;
  }

  .hero-intro,
  .section-head p,
  .feature-card p,
  .provider-copy p,
  .roadmap-card p,
  .product-shot figcaption {
    color: var(--fg-muted);
    font-size: 1.06rem;
    line-height: 1.62;
  }

  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .hero-chips span {
    border: 1px solid rgba(244, 241, 232, 0.16);
    border-radius: 999px;
    background: rgba(244, 241, 232, 0.045);
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.42rem 0.58rem;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 0.35rem;
  }

  .button {
    min-height: 2.85rem;
    justify-content: center;
    gap: 0.58rem;
    border: 1px solid transparent;
    border-radius: 7px;
    padding: 0.78rem 1rem;
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1;
    transition:
      transform 150ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 150ms ease,
      background 150ms ease,
      box-shadow 150ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button-primary {
    background: var(--fg);
    color: var(--ink);
    box-shadow: 0 0 0 rgba(244, 241, 232, 0);
  }

  .button-primary:hover {
    box-shadow: 0 16px 38px rgba(244, 241, 232, 0.12);
  }

  .button-secondary {
    border-color: var(--line-strong);
    background: rgba(244, 241, 232, 0.045);
    color: var(--fg);
  }

  .button-secondary:hover {
    border-color: rgba(244, 241, 232, 0.42);
    background: rgba(244, 241, 232, 0.075);
  }

  .cta-icon {
    display: none;
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
  }

  .cta-icon--linux {
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 800;
    line-height: 1;
  }

  :global([data-platform="mac"]) .cta-icon--apple,
  :global([data-platform="win"]) .cta-icon--windows {
    display: block;
  }

  :global([data-platform="linux"]) .cta-icon--linux {
    display: inline-grid;
  }

  .product-shot {
    display: grid;
    gap: 0.75rem;
    min-width: 0;
    margin: 0;
    transform-origin: center;
    transition:
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 220ms ease;
  }

  .product-window {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(244, 241, 232, 0.22);
    border-radius: 10px;
    background:
      linear-gradient(180deg, rgba(244, 241, 232, 0.07), rgba(244, 241, 232, 0.025)),
      var(--surface);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 calc(18px + 18px * var(--scroll-shadow, 1))
        calc(54px + 36px * var(--scroll-shadow, 1)) rgba(0, 0, 0, 0.34);
    transition:
      border-color 180ms ease,
      box-shadow 220ms ease,
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .product-window::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      120deg,
      rgba(255, 255, 255, calc(0.055 + 0.05 * var(--scroll-shadow, 1))),
      transparent 24%,
      transparent 72%
    );
    opacity: 0.82;
  }

  .product-window-bar {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
    min-height: 2.25rem;
    border-bottom: 1px solid var(--line);
    padding: 0 0.75rem;
  }

  .window-controls {
    display: flex;
    gap: 0.34rem;
  }

  .window-controls i {
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 999px;
    background: var(--fg-dim);
    opacity: 0.58;
  }

  .window-title,
  .window-status {
    overflow: hidden;
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .window-status {
    color: var(--success);
  }

  .product-window img,
  .screenshot-band img {
    width: 100%;
    height: auto;
    background: #050607;
  }

  .product-window-bar,
  .product-window img {
    position: relative;
    z-index: 1;
  }

  .screenshot-band img {
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    box-shadow: 0 calc(16px + 20px * var(--scroll-shadow, 1))
      calc(44px + 44px * var(--scroll-shadow, 1)) rgba(0, 0, 0, 0.26);
    transition:
      border-color 180ms ease,
      box-shadow 220ms ease,
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .product-window img {
    display: block;
    max-height: min(31rem, calc(100svh - 15.25rem));
    object-fit: contain;
  }

  .product-shot:hover .product-window,
  .product-shot:focus-visible .product-window {
    border-color: rgba(244, 241, 232, 0.36);
    box-shadow: 0 calc(24px + 22px * var(--scroll-shadow, 1))
      calc(68px + 38px * var(--scroll-shadow, 1)) rgba(0, 0, 0, 0.42);
  }

  .product-shot figcaption {
    max-width: 46rem;
    color: var(--fg-dim);
    font-size: 0.88rem;
  }

  .facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(244, 241, 232, 0.022);
  }

  .motion-ready .facts,
  .motion-ready .feature-grid,
  .motion-ready .provider-story,
  .motion-ready .roadmap-grid,
  .motion-ready .final-cta {
    box-shadow: 0 calc(10px + 18px * var(--scroll-shadow, 1))
      calc(28px + 34px * var(--scroll-shadow, 1)) rgba(0, 0, 0, 0.13);
  }

  .facts div {
    display: grid;
    gap: 0.35rem;
    min-height: 7rem;
    align-content: center;
    padding: 1rem 1.1rem;
    transition:
      background 180ms ease,
      transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .facts div:hover {
    background: rgba(244, 241, 232, 0.035);
    transform: translateY(-1px);
  }

  .facts div + div {
    border-left: 1px solid var(--line);
  }

  .facts span,
  .feature-card span,
  .provider-copy span,
  .roadmap-card span {
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  .facts strong {
    color: var(--fg);
    font-size: 1.12rem;
    line-height: 1.25;
  }

  .feature-band {
    padding: clamp(4.5rem, 8vw, 7.5rem) 0;
  }

  .section-head {
    max-width: 56rem;
    margin-bottom: 3rem;
  }

  .section-head.compact {
    max-width: 48rem;
  }

  .section-head h2,
  .final-cta h2 {
    color: var(--fg);
    font-size: 4.8rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.94;
  }

  .feature-grid {
    display: grid;
