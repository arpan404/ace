---
import Layout from "../layouts/Layout.astro";
import ProviderFloat from "../components/ProviderFloat.astro";
---

<Layout
  title="ace — The control surface for coding agents"
  description="ace is a local workbench for running Codex, Claude, Gemini, Cursor, GitHub Copilot, and OpenCode with project threads, terminal context, browser checks, mobile access, and recovery built in."
>
  <section class="hero" aria-labelledby="hero-heading">
    <nav class="site-nav" aria-label="Primary">
      <a href="/" class="brand" aria-label="ace home">
        <img src="/logo.png" alt="" class="brand-icon" />
        <span>ace</span>
      </a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#workflow">Workflow</a>
        <a href="/changelog">Changelog</a>
        <a href="https://github.com/arpan404/ace" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </nav>

    <div class="hero-grid">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">Local GUI for agentic coding</p>
        <h1 id="hero-heading">Run agents like real work.</h1>
        <p class="hero-intro">
          ace turns Codex, Claude, Gemini, Cursor, Copilot, and OpenCode into one project-aware
          workspace. Threads, tools, terminals, browser checks, remote hosts, and recovery all stay
          attached to the repo that needs the work.
        </p>
        <div class="hero-actions" aria-label="Primary actions">
          <a id="download-btn" href="/download" class="button button-primary">
            <svg class="cta-icon cta-icon--apple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" aria-hidden="true"><path fill="currentColor" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>
            <svg class="cta-icon cta-icon--windows" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/></svg>
            <span id="download-label">Download ace</span>
          </a>
          <a href="#features" class="button button-secondary">Explore the product</a>
        </div>
      </div>

      <div class="hero-stage" data-hero-stage aria-label="Ace product preview">
        <div class="stage-toolbar" aria-hidden="true">
          <span>ace://local</span>
          <span class="toolbar-live">streaming</span>
        </div>
        <div class="product-frame">
          <img
            src="/screenshot.png"
            alt="ace desktop app showing an agent thread, project sidebar, and composer"
            class="product-image"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
        <div class="callout callout-project" aria-hidden="true">
          <span>Project context</span>
          <strong>worktree + branch attached</strong>
        </div>
        <div class="callout callout-stream" aria-hidden="true">
          <span>Live turn</span>
          <strong>tool calls visible</strong>
        </div>
        <div class="callout callout-review" aria-hidden="true">
          <span>Review loop</span>
          <strong>browser + diff before handoff</strong>
        </div>
      </div>
    </div>

    <div class="hero-metrics" aria-label="Ace capabilities">
      <div><strong>6</strong><span>agent providers</span></div>
      <div><strong>3</strong><span>surfaces: desktop, web, mobile</span></div>
      <div><strong>1</strong><span>timeline for prompts, tools, terminals, and recovery</span></div>
    </div>
  </section>

  <section class="provider-band" aria-labelledby="providers-heading">
    <div class="section-head compact" data-reveal>
      <p class="eyebrow">Bring your existing CLIs</p>
      <h2 id="providers-heading">One control surface. No provider lock-in.</h2>
      <p>
        ace detects installed agent CLIs, keeps provider status visible, and lets each project carry
        the model choice that fits the work.
      </p>
    </div>
    <ProviderFloat />
  </section>

  <section id="features" class="feature-runway" aria-labelledby="features-heading">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Product surfaces</p>
      <h2 id="features-heading">Everything the agent touches stays inspectable.</h2>
      <p>
        The interface is built around the messy middle of coding-agent work: partial streams,
        approvals, terminals, file changes, browser verification, reconnects, and interrupted turns.
      </p>
    </div>

    <div class="feature-panel feature-panel-large" data-feature-panel>
      <div class="feature-visual orchestration-visual" aria-hidden="true">
        <div class="mini-sidebar">
          <span class="active">ace</span>
          <span>server</span>
          <span>desktop</span>
          <span>mobile</span>
        </div>
        <div class="mini-thread">
          <div class="mini-line user">Refactor model picker and verify responsive behavior.</div>
          <div class="mini-line plan">plan proposed · approval required</div>
          <div class="mini-line tool">read apps/web/src/components</div>
          <div class="mini-line tool">edit ProviderModelPicker.tsx</div>
          <div class="mini-line result">checkpoint ready · +42 -17</div>
        </div>
      </div>
      <div class="feature-copy">
        <span class="feature-number">01</span>
        <h3>Threads are operational logs, not chat transcripts.</h3>
        <p>
          User prompts, proposed plans, provider sessions, tool activity, terminal contexts, queued
          steering, checkpoints, and errors all project into the same readable timeline.
        </p>
      </div>
    </div>

    <div class="feature-grid">
      <article class="feature-card" data-feature-panel>
        <div class="card-terminal" aria-hidden="true">
          <span>$ bun fmt</span>
          <span>$ bun lint</span>
          <span>$ bun typecheck</span>
          <strong>all checks green</strong>
        </div>
        <h3>Terminal context rides with the task.</h3>
        <p>Terminal output, titles, history, and cleanup are tied to the thread instead of floating in a separate window.</p>
      </article>
      <article class="feature-card" data-feature-panel>
        <div class="card-browser" aria-hidden="true">
          <div class="browser-top"><span></span><span></span><span></span></div>
          <div class="browser-body">
            <span style="--w: 72%"></span>
            <span style="--w: 48%"></span>
            <span style="--w: 84%"></span>
          </div>
        </div>
        <h3>Browser checks are first-class.</h3>
        <p>Open app URLs, preserve tabs per thread, repair browser storage, and verify UI work before you accept a patch.</p>
      </article>
      <article class="feature-card" data-feature-panel>
        <div class="card-remote" aria-hidden="true">
          <span>desktop host</span>
          <i></i>
          <span>mobile client</span>
        </div>
        <h3>Remote access is built around hosts.</h3>
        <p>Pair devices with QR or connection strings, switch hosts, and monitor project agent counts from mobile.</p>
      </article>
    </div>
  </section>

  <section id="workflow" class="workflow" aria-labelledby="workflow-heading">
    <div class="section-head compact" data-reveal>
      <p class="eyebrow">Daily path</p>
      <h2 id="workflow-heading">Prompt to patch without losing state.</h2>
    </div>
    <div class="workflow-track" aria-label="Ace workflow">
      <article data-workflow-card>
        <span>01</span>
        <h3>Open a project.</h3>
        <p>Add a repo, keep default model selection with the project, and start a thread inside its workspace root.</p>
      </article>
      <article data-workflow-card>
        <span>02</span>
        <h3>Choose runtime.</h3>
        <p>Run with approval-required or full-access modes, then watch provider status and active turn state update live.</p>
      </article>
      <article data-workflow-card>
        <span>03</span>
        <h3>Inspect the run.</h3>
        <p>Read tool calls, terminal output, plans, diffs, pending approvals, and user-input requests in one timeline.</p>
      </article>
      <article data-workflow-card>
        <span>04</span>
        <h3>Recover cleanly.</h3>
        <p>Archive, pin, resume, hand off, or reconnect to long-running sessions without rebuilding context from memory.</p>
      </article>
    </div>
  </section>

  <section class="reliability" aria-labelledby="reliability-heading">
    <div class="reliability-copy" data-reveal>
      <p class="eyebrow">Built for failure modes</p>
      <h2 id="reliability-heading">The boring parts are product features.</h2>
      <p>
        ace is designed for the moments when agent work usually gets vague: partial streams,
        provider restarts, stale browser state, orphaned worktrees, remote reconnects, and long
        histories that need to stay fast.
      </p>
    </div>
    <div class="reliability-console" data-feature-panel aria-label="Reliability features">
      <div><span>snapshot cache</span><strong>lean thread hydration</strong></div>
      <div><span>orchestration events</span><strong>append-only projection</strong></div>
      <div><span>worktree cleanup</span><strong>confirm before delete</strong></div>
      <div><span>provider runtime</span><strong>session restart recovery</strong></div>
    </div>
  </section>

  <section class="final-cta" aria-labelledby="final-heading">
    <div class="final-copy" data-reveal>
      <p class="eyebrow">Desktop-first. Remote-ready.</p>
      <h2 id="final-heading">Give every coding agent one desk.</h2>
      <p>Download ace, connect the provider CLIs you already use, and keep the work visible from prompt to verification.</p>
    </div>
    <a href="/download" class="button button-primary">Download ace</a>
  </section>
</Layout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  type Platform = { os: "mac" | "win" | "linux"; label: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) return { os: "mac", label: "Download for macOS" };
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  function initDownloadLink() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    const platform = detectPlatform();
    if (!btn || !label || !platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;
  }

  function initMotion() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo(
      "[data-hero-stage]",
      { y: 34, rotateX: 6, opacity: 0 },
      { y: 0, rotateX: 0, opacity: 1, duration: 0.85, ease: "power3.out" },
    );

    gsap.utils.toArray<HTMLElement>("[data-reveal]").forEach((element) => {
      gsap.fromTo(
        element,
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.65,
          ease: "power3.out",
          scrollTrigger: { trigger: element, start: "top 86%" },
        },
      );
    });

    gsap.utils.toArray<HTMLElement>("[data-feature-panel]").forEach((element) => {
      gsap.fromTo(
        element,
        { y: 56, opacity: 0.55, scale: 0.97 },
        {
          y: 0,
          opacity: 1,
          scale: 1,
          ease: "none",
          scrollTrigger: {
            trigger: element,
            start: "top 92%",
            end: "top 48%",
            scrub: true,
          },
        },
      );
    });

    gsap.utils.toArray<HTMLElement>("[data-workflow-card]").forEach((card, index) => {
      gsap.fromTo(
        card,
        { y: 42, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.58,
          delay: index * 0.04,
          ease: "power3.out",
          scrollTrigger: { trigger: card, start: "top 88%" },
        },
      );
    });
  }

  initDownloadLink();
  initMotion();
</script>

<style>
  .hero,
  .provider-band,
  .feature-runway,
  .workflow,
  .reliability,
  .final-cta {
    width: min(100% - 2rem, 1220px);
    margin: 0 auto;
  }

  .hero {
    min-height: 100dvh;
    padding: clamp(1rem, 2vw, 1.4rem) 0 clamp(3rem, 7vw, 6rem);
  }

  .site-nav,
  .hero-grid,
  .hero-metrics,
  .feature-panel,
  .reliability,
  .final-cta {
    border: 1px solid var(--line);
    background: rgba(242, 238, 228, 0.035);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4rem;
    padding: 0.65rem 0.75rem;
  }

  .brand,
  .nav-links,
  .hero-actions,
  .button,
  .stage-toolbar,
  .hero-metrics,
  .card-remote {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 0.7rem;
    font-size: 1.05rem;
    font-weight: 800;
  }

  .brand-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 6px;
  }

  .nav-links {
    gap: clamp(0.65rem, 2vw, 1.4rem);
    color: var(--fg-muted);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .nav-links a {
    transition: color 150ms ease;
  }

  .nav-links a:hover {
    color: var(--fg);
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.75fr) minmax(28rem, 1.25fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    min-height: clamp(38rem, 78vh, 52rem);
    margin-top: 0.75rem;
    overflow: hidden;
    padding: clamp(1.2rem, 4vw, 3rem);
  }

  .hero-grid::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(255, 181, 69, 0.08), transparent 34%),
      linear-gradient(135deg, transparent 0 49.7%, rgba(0, 212, 255, 0.18) 49.8% 50%, transparent 50.1%);
    pointer-events: none;
  }

  .hero-copy,
  .hero-stage,
  .section-head,
  .feature-copy,
  .reliability-copy,
  .final-copy {
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    display: grid;
    gap: 1.35rem;
    max-width: 39rem;
  }

  .eyebrow {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero h1 {
    max-width: 9ch;
    color: var(--fg);
    font-size: clamp(4rem, 8.7vw, 8.8rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.82;
    text-wrap: balance;
  }

  .hero-intro,
  .section-head p,
  .feature-copy p,
  .feature-card p,
  .workflow-track p,
  .reliability-copy p,
  .final-copy p {
    color: var(--fg-muted);
    font-size: clamp(1rem, 1.3vw, 1.12rem);
    line-height: 1.62;
  }

  .hero-intro {
    max-width: 38rem;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button {
    min-height: 3.05rem;
    justify-content: center;
    gap: 0.65rem;
    border: 1px solid transparent;
    border-radius: 6px;
    padding: 0.86rem 1.05rem;
    font-weight: 800;
    line-height: 1;
    transition:
      transform 160ms ease,
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button-primary {
    background: var(--fg);
    color: var(--ink);
  }

  .button-secondary {
    border-color: var(--line-strong);
    color: var(--fg);
  }

  .button-secondary:hover {
    background: rgba(242, 238, 228, 0.08);
  }

  .cta-icon {
    display: none;
    width: 1rem;
    height: 1rem;
  }

  :global([data-platform="mac"]) .cta-icon--apple,
  :global([data-platform="win"]) .cta-icon--windows {
    display: block;
  }

  .hero-stage {
    justify-self: end;
    width: min(100%, 45rem);
    perspective: 1200px;
  }

  .stage-toolbar {
    justify-content: space-between;
    border: 1px solid var(--line);
    border-bottom: 0;
    background: rgba(8, 10, 15, 0.88);
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.65rem 0.8rem;
  }

  .toolbar-live {
    color: var(--accent);
  }

  .toolbar-live::before {
    content: "";
    display: inline-block;
    width: 0.42rem;
    height: 0.42rem;
    margin-right: 0.45rem;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 18px rgba(0, 212, 255, 0.75);
  }

  .product-frame {
    overflow: hidden;
    border: 1px solid var(--line);
    background: #07090d;
    padding: 0.65rem;
    box-shadow: 0 34px 96px rgba(0, 0, 0, 0.45);
  }

  .product-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: 50% 0%;
    filter: saturate(0.92) contrast(1.08);
  }

  .callout {
    position: absolute;
    display: grid;
    gap: 0.15rem;
    min-width: 12rem;
    border: 1px solid rgba(0, 212, 255, 0.28);
    background: rgba(8, 10, 15, 0.9);
    padding: 0.7rem 0.8rem;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
    animation: float-callout 5s ease-in-out infinite;
  }

  .callout span {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .callout strong {
    color: var(--fg);
    font-size: 0.88rem;
    line-height: 1.2;
  }

  .callout-project {
    left: -1.4rem;
    top: 19%;
  }

  .callout-stream {
    right: -1.1rem;
    top: 48%;
    animation-delay: -1.3s;
  }

  .callout-review {
    bottom: -1.25rem;
    left: 22%;
    border-color: rgba(255, 181, 69, 0.34);
    animation-delay: -2.4s;
  }

  .callout-review span {
    color: var(--review);
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 0.75rem;
  }

  .hero-metrics div {
    display: grid;
    gap: 0.15rem;
    min-height: 6rem;
    align-content: center;
    padding: 1rem;
  }

  .hero-metrics div + div {
    border-left: 1px solid var(--line);
  }

  .hero-metrics strong {
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: clamp(1.9rem, 4vw, 3.2rem);
    line-height: 1;
  }

  .hero-metrics span {
    color: var(--fg-muted);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .provider-band,
  .feature-runway,
  .workflow,
  .reliability {
    padding: clamp(5rem, 10vw, 9rem) 0;
  }

  .section-head {
    display: grid;
    gap: 0.85rem;
    max-width: 56rem;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  .section-head.compact {
    max-width: 45rem;
  }

  .section-head h2,
  .feature-copy h3,
  .reliability-copy h2,
  .final-copy h2 {
    color: var(--fg);
    font-size: clamp(2.5rem, 5.5vw, 5.8rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.9;
    text-wrap: balance;
  }

  .feature-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.7fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: stretch;
    padding: clamp(1rem, 3vw, 1.5rem);
  }

  .feature-panel-large {
    min-height: 34rem;
  }

  .feature-visual,
  .feature-card {
    border: 1px solid var(--line);
    background: rgba(8, 10, 15, 0.72);
  }

  .orchestration-visual {
    display: grid;
    grid-template-columns: 10rem 1fr;
    min-height: 28rem;
    overflow: hidden;
  }

  .mini-sidebar {
    display: grid;
    gap: 0.5rem;
    align-content: start;
    border-right: 1px solid var(--line);
    padding: 1rem;
  }

  .mini-sidebar span,
  .mini-line,
  .card-terminal span,
  .card-terminal strong,
  .card-remote span,
  .reliability-console span,
  .reliability-console strong {
    font-family: var(--font-mono);
  }

  .mini-sidebar span {
    color: var(--fg-dim);
    font-size: 0.78rem;
    padding: 0.55rem;
  }

  .mini-sidebar .active {
    background: rgba(0, 212, 255, 0.1);
    color: var(--fg);
  }

  .mini-thread {
    display: grid;
    gap: 0.7rem;
    align-content: center;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .mini-line {
    border: 1px solid var(--line);
    color: var(--fg-muted);
    font-size: clamp(0.76rem, 1.2vw, 0.92rem);
    padding: 0.8rem;
    transform-origin: left center;
  }

  .mini-line.user,
  .mini-line.result {
    color: var(--fg);
  }

  .mini-line.plan {
    color: var(--review);
  }

  .mini-line.tool {
    color: var(--accent);
  }

  .feature-copy {
    display: grid;
    align-content: end;
    gap: 1rem;
    padding: clamp(0.5rem, 2vw, 1rem);
  }

  .feature-number {
    color: var(--review);
    font-family: var(--font-mono);
    font-size: 0.86rem;
    font-weight: 800;
  }

  .feature-copy h3 {
    font-size: clamp(2.2rem, 4.5vw, 4.7rem);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
