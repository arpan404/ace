---
import Layout from "../layouts/Layout.astro";
import WorkspaceDemo from "../components/WorkspaceDemo.astro";
import ProviderFloat from "../components/ProviderFloat.astro";
---

<Layout
  title="ace — Unified Agent Workspace"
  description="One workspace for all your coding agents. Browser, editor, design mode, code review, and multi-agent orchestration—no context switching, bring your own subscription."
>
  <!-- Hero Section -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-content animate-fade">
      <p class="eyebrow">The Unified Coding Agent Workspace</p>
      <h1 id="hero-heading" class="tagline">
        Build with the best, <br />
        <span class="text-gradient">in one place.</span>
      </h1>
      <p class="intro">
        ace brings browser, code editor, design mode, and orchestration together in a single workspace. 
        Bring your own subscription, coordinate multiple agents, and ship faster—all without leaving the app.
      </p>
      
      <div class="hero-ctas">
        <a id="download-btn" href="/download" class="cta-primary">
           <svg class="cta-icon cta-icon--apple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" aria-hidden="true"><path fill="currentColor" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>
           <svg class="cta-icon cta-icon--windows" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/></svg>
           <span id="download-label">Download for macOS</span>
        </a>
        <a href="https://github.com/arpan404/ace" class="cta-secondary">
          Star on GitHub <span class="stars">★ 1.2k</span>
        </a>
      </div>
    </div>

    <!-- The central interactive piece -->
    <div class="hero-demo animate-fade delay-1">
      <WorkspaceDemo />
    </div>
  </section>

  <!-- Provider Carousel -->
  <section class="providers">
    <div class="section-header">
      <h2>Bring your favorite providers</h2>
      <p>Connect any agent using your own subscription. No vendor lock-in.</p>
    </div>
    <ProviderFloat />
  </section>

  <!-- Detailed Feature Grid -->
  <section id="features" class="features" aria-labelledby="features-heading">
    <div class="section-header">
      <h2 id="features-heading">Continuity by design</h2>
      <p>Stop hopping between apps. ace brings the entire workflow together.</p>
    </div>
    
    <div class="feature-grid">
      <article class="feature-card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 16V12M12 8H12.01"></path></svg>
        </div>
        <h3>Multi-agent Orchestration</h3>
        <p>Coordinate multiple specialized agents. Let Codex handle the design while Claude reviews the logic.</p>
      </article>

      <article class="feature-card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
        </div>
        <h3>In-app Live Browser</h3>
        <p>Test and preview UI changes in real-time. Toggle Design Mode to visually inspect and edit components.</p>
      </article>

      <article class="feature-card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
        </div>
        <h3>Integrated Editor</h3>
        <p>A fast, agent-aware editor with smart suggestions, syntax highlighting, and project context.</p>
      </article>

      <article class="feature-card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 13h5.293l3.354 3.354c.195.195.512.195.707 0L22 6.06"></path></svg>
        </div>
        <h3>Bring Your Own Sub</h3>
        <p>No extra auth layers. Connect your existing Codex, Claude, or Gemini credentials and start building.</p>
      </article>
    </div>
  </section>

  <!-- Remote Control Section -->
  <section class="remote-control">
    <div class="remote-content">
      <h2>Remote Control & Deployment</h2>
      <p>Control your workspace from anywhere. One-click deployments to your favorite cloud providers.</p>
      <div class="remote-visual">
         <div class="remote-tag">ssh://ace-remote</div>
         <div class="remote-typing">Deployment successful.</div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="cta-box">
      <h2>Ready to ship faster?</h2>
      <p>Join 2,000+ developers building with ace.</p>
      <div class="hero-ctas centered">
        <a href="/download" class="cta-primary">Download now</a>
        <a href="https://discord.gg/jn4EGJjrvv" class="cta-secondary">Join Discord</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { fetchLatestRelease, RELEASES_URL, type ReleaseAsset } from "../lib/releases";

  type Platform = { os: "mac" | "win" | "linux"; label: string; arch?: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) {
      return {
        os: "mac",
        label: `Download for macOS`,
        arch: "arm64",
      };
    }
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  function pickAsset(assets: ReleaseAsset[], platform: Platform): string | null {
    if (platform.os === "win") {
      return (
        assets.find((a) => a.name.endsWith("-x64.exe"))
          ?.browser_download_url ?? null
      );
    }
    if (platform.os === "mac") {
      const preferred = assets.find((a) =>
        a.name.endsWith(`-${platform.arch}.dmg`),
      );
      const fallback = assets.find((a) => a.name.endsWith(".dmg"));
      return (preferred ?? fallback)?.browser_download_url ?? null;
    }
    if (platform.os === "linux") {
      return (
        assets.find((a) => a.name.endsWith(".AppImage"))
          ?.browser_download_url ?? null
      );
    }
    return null;
  }

  async function init() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    if (!btn || !label) return;

    const platform = detectPlatform();
    if (!platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;

    try {
      const release = await fetchLatestRelease();
      const url = pickAsset(release.assets ?? [], platform);
      if (url) {
        btn.href = url;
      }
    } catch {
      btn.href = RELEASES_URL;
    }
  }

  init();
</script>

<style>
  /* ── Hero Section ── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 6rem 2rem 4rem;
    text-align: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .tagline {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
  }

  .text-gradient {
    background: linear-gradient(to right, var(--fg), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .intro {
    font-size: 1.25rem;
    color: var(--fg-muted);
    max-width: 600px;
    margin-bottom: 3rem;
    line-height: 1.6;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    margin-bottom: 5rem;
  }

  .hero-ctas.centered { justify-content: center; margin-bottom: 0; }

  .cta-primary {
    background: var(--fg);
    color: var(--bg);
    padding: 0.85rem 2rem;
    border-radius: 999px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    box-shadow: 0 4px 20px oklch(1 0 0 / 0.2);
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px oklch(1 0 0 / 0.3);
  }

  .cta-secondary {
    background: oklch(1 0 0 / 0.05);
    color: var(--fg);
    padding: 0.85rem 2rem;
    border-radius: 999px;
    font-weight: 600;
    border: 1px solid var(--border);
  }

  .cta-secondary:hover {
    background: oklch(1 0 0 / 0.1);
    border-color: var(--border-bright);
  }

  .cta-icon {
    width: 1.2rem;
    height: 1.2rem;
    display: none;
  }

  :global([data-platform="mac"]) .cta-icon--apple { display: block; }
  :global([data-platform="win"]) .cta-icon--windows { display: block; }

  .stars {
    color: var(--fg-dim);
    font-size: 0.85rem;
    margin-left: 0.5rem;
  }

  .hero-demo {
    width: 100%;
    position: relative;
  }

  .hero-demo::before {
    content: "";
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 110%;
    height: 110%;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    z-index: -1;
  }

  /* ── Sections Common ── */
  section {
    padding: 6rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .section-header p {
    color: var(--fg-muted);
    font-size: 1.1rem;
  }

  /* ── Feature Grid ── */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    background: oklch(1 0 0 / 0.03);
    border: 1px solid var(--border);
    padding: 2.5rem;
    border-radius: 24px;
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    background: oklch(1 0 0 / 0.05);
    border-color: var(--border-bright);
    transform: translateY(-5px);
  }

  .card-icon {
    width: 48px;
    height: 48px;
    background: var(--accent-glow);
    color: var(--accent);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .card-icon svg { width: 24px; height: 24px; }

  .feature-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .feature-card p {
    color: var(--fg-muted);
    line-height: 1.6;
  }

  /* ── Remote Control ── */
  .remote-control {
    background: radial-gradient(circle at 100% 100%, oklch(0.1 0.05 250 / 0.3) 0%, transparent 50%);
    border-radius: 40px;
    margin: 4rem auto;
    border: 1px solid var(--border);
    text-align: left;
    display: flex;
    align-items: center;
    gap: 4rem;
  }

  .remote-content { flex: 1; }
  .remote-visual {
    flex: 1;
    background: oklch(0 0 0);
    border-radius: 16px;
    padding: 2rem;
    font-family: var(--font-mono);
    border: 1px solid var(--border-bright);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .remote-tag { color: var(--accent); margin-bottom: 1rem; font-size: 0.9rem; }
  .remote-typing { border-right: 2px solid var(--accent); width: fit-content; animation: blink 1s infinite; padding-right: 4px; }

  @keyframes blink { 50% { border-color: transparent; } }

  /* ── Final CTA ── */
  .final-cta { padding-bottom: 10rem; }
  .cta-box {
    background: linear-gradient(to bottom right, oklch(0.12 0.02 250), oklch(0.08 0.01 250));
    padding: 6rem 2rem;
    border-radius: 40px;
    text-align: center;
    border: 1px solid var(--border);
  }

  .cta-box h2 { font-size: 3rem; margin-bottom: 1rem; }
  .cta-box p { font-size: 1.2rem; color: var(--fg-muted); margin-bottom: 3rem; }

  /* ── Utilities ── */
  .delay-1 { animation-delay: 0.2s; }

  @media (max-width: 960px) {
    .hero { padding: 4rem 1.5rem; }
    .remote-control { flex-direction: column; text-align: center; gap: 2rem; padding: 3rem 1.5rem; }
    .final-cta { padding-bottom: 4rem; }
    .cta-box h2 { font-size: 2rem; }
  }
</style>
