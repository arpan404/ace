---
import Layout from "../layouts/Layout.astro";
import ProviderFloat from "../components/ProviderFloat.astro";
import ProviderIcon from "../components/ProviderIcon.astro";

const providers = [
  { label: "Codex", kind: "codex" },
  { label: "Claude", kind: "claude" },
  { label: "Gemini", kind: "gemini" },
  { label: "Cursor", kind: "cursor" },
  { label: "GitHub Copilot", kind: "githubCopilot" },
  { label: "OpenCode", kind: "opencode" },
] as const;

const systemRows = [
  {
    label: "Project threads",
    title: "Runs stay attached to a repo instead of disappearing into fresh chats.",
    text: "Approvals, checkpoints, browser state, editor context, and event history stay with the work so supervision does not depend on memory.",
  },
  {
    label: "Review surfaces",
    title: "Browser, editor, terminal, and diffs stay nearby while decisions are being made.",
    text: "The operator does not need to bounce across windows to understand what changed, what failed, or what needs approval next.",
  },
  {
    label: "Recovery",
    title: "Long sessions remain readable when streams break, reconnect, or restart.",
    text: "ace is designed around the awkward parts of real agent work, not just the happy-path screenshot.",
  },
  {
    label: "Performance",
    title: "Dense histories and local context stay usable under load.",
    text: "The interface is shaped for supervision of active work rather than lightweight prompt demos.",
  },
] as const;

const shiftRows = [
  {
    index: "01",
    title: "Start where the repo can actually run",
    text: "Use local provider CLIs, attach terminal context, and keep execution on the machine that holds the code and tools.",
  },
  {
    index: "02",
    title: "Switch providers without losing continuity",
    text: "Move between agents as the task changes while the same thread retains browser checks, history, approvals, and review state.",
  },
  {
    index: "03",
    title: "Monitor and steer from another device",
    text: "Remote hosts keep work near the environment while the interface stays available on the machine you want to carry.",
  },
] as const;

const remoteModes = [
  {
    label: "Single workstation",
    detail: "One heavy local machine running repo work with the full interface beside it.",
  },
  {
    label: "Multiple hosts",
    detail: "Separate workstations, servers, or sandboxes available through the same workspace.",
  },
  {
    label: "Headless runtime",
    detail: "The host runs where the code lives while the interface stays elsewhere.",
  },
] as const;

const roadmapRows = [
  {
    label: "Flow Mode",
    text: "Coordinated multi-agent loops where providers can pass responsibility across backend, web, mobile, and test work without breaking the run narrative.",
  },
  {
    label: "Skills",
    text: "Reusable instruction packs and workflow standards so teams can shape agent behavior deliberately instead of reinventing prompts for every project.",
  },
] as const;
---

<Layout
  title="ace - Agent operations for real codebases"
  description="ace is a desktop and remote workspace for supervising coding agents across threads, providers, terminals, browsers, editors, and long-running recovery states."
>
  <nav class="site-nav" aria-label="Primary">
    <a href="/" class="brand" aria-label="ace home">
      <img src="/logo.png" alt="" class="brand-icon" />
      <span>ace</span>
    </a>
    <div class="nav-links">
      <a href="#system">System</a>
      <a href="#providers">Providers</a>
      <a href="#remote">Remote</a>
      <a href="#roadmap">Roadmap</a>
      <a href="/download">Download</a>
      <a href="https://github.com/arpan404/ace" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </nav>

  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-copy" data-reveal>
      <p class="eyebrow">Multi-provider workspace for serious agent work</p>
      <h1 id="hero-heading">A real interface for supervising coding agents.</h1>
      <p class="hero-intro">
        ace keeps the work legible while it is running: project threads, terminal context, browser
        checks, editor review, provider handoff, and recovery when long sessions go sideways.
      </p>
      <div class="hero-actions" aria-label="Primary actions">
        <a id="download-btn" href="/download" class="button button-primary" data-interactive>
          <svg
            class="cta-icon cta-icon--apple"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 814 1000"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"
            />
          </svg>
          <svg
            class="cta-icon cta-icon--windows"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 88 88"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"
            />
          </svg>
          <span class="cta-icon cta-icon--linux" aria-hidden="true">Lx</span>
          <span id="download-label">Download ace</span>
        </a>
        <a href="#system" class="button button-secondary" data-interactive>See how it works</a>
      </div>
    </div>

    <div class="hero-stage" data-reveal data-scroll-3d data-scroll-strength="1.04">
      <div class="hero-stage__rail">
        <div>
          <span>Providers</span>
          <strong>Codex, Claude, Gemini, Cursor, Copilot, OpenCode</strong>
        </div>
        <div>
          <span>Environment</span>
          <strong>Desktop UI plus remote host sessions</strong>
        </div>
        <div>
          <span>Behavior</span>
          <strong>Local-first, recoverable, thread-based supervision</strong>
        </div>
      </div>

      <figure class="hero-canvas" data-interactive>
        <figcaption class="hero-canvas__caption">
          <div>
            <span>Workspace view</span>
            <strong>Conversation, browser, diffs, and execution state in one frame</strong>
          </div>
          <small>Live supervision surface</small>
        </figcaption>
        <img
          src="/screenshot.png"
          alt="ace desktop workspace showing project threads, a coding agent conversation, and review panels"
          width="3456"
          height="2168"
          loading="eager"
          decoding="async"
        />
        <div class="hero-canvas__notes" aria-hidden="true">
          <span>Thread history stays visible</span>
          <span>Browser pass beside the run</span>
          <span>Terminal context attached to the task</span>
        </div>
      </figure>
    </div>
  </section>

  <section class="run-strip" aria-label="Run characteristics" data-scroll-3d data-scroll-strength="0.35">
    <div data-reveal>
      <span>What matters</span>
      <p>The run stays readable while work is happening, failing, and getting handed off.</p>
    </div>
    <div data-reveal>
      <span>What you can do</span>
      <p>Inspect, redirect, approve, and recover without rebuilding context from memory.</p>
    </div>
    <div data-reveal>
      <span>What happens next</span>
      <p>ace is moving toward persistent multi-agent workflows rather than isolated turns.</p>
    </div>
  </section>

  <section id="system" class="system-section page-section" aria-labelledby="system-heading">
    <div class="section-label" data-reveal>
      <p class="eyebrow">System</p>
      <h2 id="system-heading">Everything you need to keep agent work under control.</h2>
    </div>

    <div class="section-body">
      <p class="section-intro" data-reveal>
        ace keeps the important surfaces together so you can understand what is happening and decide
        what to do next without context switching.
      </p>

      <div class="system-list" role="list">
        {systemRows.map((row) => (
          <article class="system-row" role="listitem" data-reveal>
            <span>{row.label}</span>
            <div>
              <h3>{row.title}</h3>
              <p>{row.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="providers" class="providers-section page-section" aria-labelledby="providers-heading">
    <div class="section-label" data-reveal>
      <p class="eyebrow">Providers</p>
      <h2 id="providers-heading">Switch agents without starting over.</h2>
    </div>

    <div class="section-body section-body--wide providers-layout">
      <div class="providers-summary">
        <p class="section-intro" data-reveal>
          Bring the provider accounts and CLIs you already trust. ace keeps the project narrative
          continuous while responsibility moves between agents.
        </p>

        <div class="provider-roster" data-reveal>
          {providers.map((provider) => (
            <div class="provider-roster__item">
              <ProviderIcon kind={provider.kind} />
              <span>{provider.label}</span>
            </div>
          ))}
        </div>

        <div class="provider-float-wrap" data-reveal>
          <ProviderFloat />
        </div>
      </div>

      <ol class="shift-list" aria-label="Example provider flow">
        {shiftRows.map((row) => (
          <li data-reveal>
            <span>{row.index}</span>
            <div>
              <h3>{row.title}</h3>
              <p>{row.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section id="remote" class="remote-section page-section" aria-labelledby="remote-heading">
    <div class="section-label" data-reveal>
      <p class="eyebrow">Remote</p>
      <h2 id="remote-heading">Run where the code lives. Check in from anywhere.</h2>
    </div>

    <div class="section-body remote-body">
      <div class="remote-map" data-reveal data-scroll-3d data-scroll-strength="0.42">
        <div class="remote-map__lane">
          <span>Host machine</span>
          <strong>repo + provider CLIs</strong>
        </div>
        <div class="remote-map__lane">
          <span>ace daemon</span>
          <strong>session broker + thread continuity</strong>
        </div>
        <div class="remote-map__lane">
          <span>Operator interface</span>
          <strong>desktop or laptop</strong>
        </div>
      </div>

      <div class="remote-notes">
        {remoteModes.map((mode) => (
          <article class="remote-note" data-reveal>
            <span>{mode.label}</span>
            <p>{mode.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="roadmap" class="roadmap-section page-section" aria-labelledby="roadmap-heading">
    <div class="section-label" data-reveal>
      <p class="eyebrow">Roadmap</p>
      <h2 id="roadmap-heading">Built for longer-running, more connected workflows.</h2>
    </div>

    <div class="section-body">
      <p class="section-intro" data-reveal>
        The direction is toward workflows that keep moving across providers and longer time spans
        without sacrificing inspectability or operator control.
      </p>

      <div class="roadmap-list">
        {roadmapRows.map((row) => (
          <article class="roadmap-row" data-reveal>
            <span>Coming soon</span>
            <div>
              <h3>{row.label}</h3>
              <p>{row.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta" aria-labelledby="final-heading">
    <div data-reveal>
      <p class="eyebrow">Download</p>
      <h2 id="final-heading">Put agent work in a workspace built to be supervised.</h2>
      <p>
        Install ace locally, keep the thread attached to the project, and stop spreading execution,
        review, and recovery across disconnected tools.
      </p>
    </div>
    <a href="/download" class="button button-primary" data-reveal data-interactive>Download ace</a>
  </section>
</Layout>

<script>
  type Platform = { os: "mac" | "win" | "linux"; label: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) return { os: "mac", label: "Download for macOS" };
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
  const label = document.getElementById("download-label");
  const platform = detectPlatform();

  if (btn && label && platform) {
    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;
  }
</script>

<style>
  .site-nav,
  .hero,
  .run-strip,
  .page-section,
  .final-cta {
    width: min(100% - 2rem, 1240px);
    margin: 0 auto;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 5rem;
    border-bottom: 1px solid var(--line);
  }

  .brand,
  .nav-links,
  .hero-actions,
  .button {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 0.75rem;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .brand-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 0.7rem;
  }

  .nav-links {
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.85rem 1.25rem;
    color: var(--fg-muted);
    font-size: 0.88rem;
    font-weight: 650;
  }

  .nav-links a {
    position: relative;
    transition: color 150ms ease;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -0.35rem;
    left: 0;
    height: 1px;
    background: currentColor;
    opacity: 0;
    transform: scaleX(0.5);
    transition:
      opacity 150ms ease,
      transform 180ms ease;
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--fg);
  }

  .nav-links a:hover::after,
  .nav-links a:focus-visible::after {
    opacity: 0.6;
    transform: scaleX(1);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.44fr) minmax(0, 0.56fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
    padding: clamp(2.2rem, 6vw, 5rem) 0 2rem;
  }

  .hero-copy,
  .section-label,
  .final-cta > div {
    display: grid;
    gap: 1rem;
  }

  .eyebrow {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    text-wrap: balance;
  }

  .hero h1 {
    max-width: 10ch;
    font-size: clamp(3.5rem, 7vw, 6.8rem);
    line-height: 0.92;
    letter-spacing: -0.055em;
  }

  .hero-intro,
  .section-intro,
  .system-row p,
  .shift-list p,
  .remote-note p,
  .roadmap-row p,
  .final-cta p,
  .run-strip p {
    color: var(--fg-muted);
    font-size: 1rem;
    line-height: 1.65;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 0.8rem;
    padding-top: 0.35rem;
  }

  .button {
    min-height: 3rem;
    justify-content: center;
    gap: 0.58rem;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.8rem 1.15rem;
    font-size: 0.94rem;
    font-weight: 800;
    line-height: 1;
    transition:
      transform 150ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 150ms ease,
      background 150ms ease,
      box-shadow 150ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button-primary {
    background: linear-gradient(135deg, #f1f4f8, #c7ced8);
    color: #0f1620;
    box-shadow: 0 18px 38px rgba(166, 174, 185, 0.18);
  }

  .button-secondary {
    border-color: var(--line-strong);
    background: rgba(255, 255, 255, 0.035);
    color: var(--fg);
  }

  .button-secondary:hover {
    border-color: rgba(233, 238, 248, 0.3);
    background: rgba(255, 255, 255, 0.06);
  }

  .cta-icon {
    display: none;
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
  }

  .cta-icon--linux {
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 800;
    line-height: 1;
  }

  :global([data-platform="mac"]) .cta-icon--apple,
  :global([data-platform="win"]) .cta-icon--windows {
    display: block;
  }

  :global([data-platform="linux"]) .cta-icon--linux {
    display: inline-grid;
  }

  .hero-stage {
    display: grid;
    grid-template-columns: minmax(10rem, 12rem) minmax(0, 1fr);
    gap: 1.1rem;
    align-items: stretch;
  }

  .hero-stage__rail {
    display: grid;
    align-content: start;
    gap: 1.2rem;
    padding-top: 0.2rem;
  }

  .hero-stage__rail div,
  .run-strip div,
  .remote-note,
  .roadmap-row,
  .system-row,
  .shift-list li {
    padding-top: 0.9rem;
    border-top: 1px solid var(--line);
  }

  .hero-stage__rail span,
  .hero-canvas__caption span,
  .hero-canvas__notes span,
  .run-strip span,
  .system-row span,
  .provider-roster__item span,
  .remote-map__lane span,
  .remote-note span,
  .roadmap-row span,
  .shift-list span {
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero-stage__rail strong {
    display: block;
    margin-top: 0.45rem;
    font-size: 0.96rem;
    line-height: 1.45;
  }

  .hero-canvas {
    position: relative;
    min-width: 0;
    margin: 0;
    padding: 1rem 0 1.1rem;
    border-top: 1px solid var(--line);
  }

  .hero-canvas img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1.5rem;
    background: #07080d;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 calc(20px + 16px * var(--scroll-shadow, 1))
        calc(52px + 32px * var(--scroll-shadow, 1)) rgba(0, 0, 0, 0.28);
  }

  .hero-canvas__caption {
    position: absolute;
    left: 1.25rem;
    top: 0;
    z-index: 1;
    width: min(22rem, calc(100% - 8rem));
    display: grid;
    gap: 0.35rem;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    background: rgba(6, 8, 13, 0.78);
    backdrop-filter: blur(10px);
  }

  .hero-canvas__caption strong {
    font-size: 0.96rem;
    line-height: 1.4;
  }

  .hero-canvas__caption small {
    margin-top: 0.2rem;
    color: var(--fg-muted);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .hero-canvas__notes {
    position: absolute;
    right: 1.25rem;
    bottom: 2.25rem;
    z-index: 1;
    display: grid;
    gap: 0.45rem;
    justify-items: end;
  }

  .hero-canvas__notes span {
    padding: 0.5rem 0.72rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(6, 8, 13, 0.72);
    color: var(--fg-muted);
    backdrop-filter: blur(10px);
  }

  .run-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    padding: 1.25rem 0 0;
  }

  .run-strip p {
    margin-top: 0.45rem;
  }

  .page-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1rem;
    padding: clamp(3.4rem, 6vw, 5.6rem) 0 0;
  }

  .section-label {
    align-content: start;
    max-width: 54rem;
  }

  .section-label h2,
  .final-cta h2 {
    max-width: 14ch;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .section-body {
    display: grid;
    gap: 1.4rem;
    min-width: 0;
    padding-top: 0;
  }

  .section-body--wide {
    gap: 1rem;
  }

  .section-intro {
    max-width: 40rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--line);
  }

  .system-list,
  .roadmap-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0 1.5rem;
  }

  .system-row,
  .roadmap-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .system-row h3,
  .shift-list h3,
  .roadmap-row h3 {
    font-size: clamp(1.28rem, 1.6vw, 1.65rem);
    line-height: 1.12;
  }

  .system-row p,
  .roadmap-row p {
    margin-top: 0.45rem;
    max-width: 32rem;
  }

  .system-row span,
  .roadmap-row span {
    margin-bottom: 0.1rem;
  }

  .provider-roster {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem 1.1rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--line);
  }

  .provider-roster__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 2.8rem;
  }

  .provider-roster__item :global(.provider-icon) {
    width: 1.15rem;
    height: 1.15rem;
  }

  .provider-roster__item span {
    color: var(--fg);
    font-family: var(--font-sans);
    font-size: 1rem;
    letter-spacing: 0;
    text-transform: none;
  }

  .shift-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    list-style: none;
  }

  .shift-list li {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .shift-list p {
    margin-top: 0.45rem;
    max-width: 26rem;
  }

  .providers-layout {
