---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Download ace" description="Download ace for macOS, Windows, or Linux.">
  <section class="download-page" aria-labelledby="download-heading">
    <nav class="download-nav" aria-label="Download navigation">
      <a href="/" class="download-brand" aria-label="ace home">
        <img src="/logo.png" alt="" />
        <span>ace</span>
      </a>
      <a href="/" class="home-link">
        <span>Home</span>
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <path
            d="M11 4 5 10M5 4h6v6"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.7"
          />
        </svg>
      </a>
    </nav>

    <div class="download-hero">
      <div class="download-copy" data-reveal>
        <p class="small-line">Download ace</p>
        <h1 id="download-heading">Install the local workspace for coding agents.</h1>
        <p>
          Run provider CLIs from your machine, keep project threads together, and review terminal,
          browser, editor, and diff context without leaving the app.
        </p>
      </div>

      <section class="recommended-download" aria-labelledby="recommended-heading" data-reveal data-interactive>
        <div>
          <span id="version-label">Checking latest release...</span>
          <h2 id="recommended-heading">Recommended build</h2>
          <p id="recommended-copy">Detecting your platform.</p>
        </div>
        <a
          id="recommended-download"
          class="download-button is-disabled"
          href="#downloads"
          aria-disabled="true"
          data-interactive
        >
          <span>Loading download</span>
        </a>
      </section>
    </div>

    <section class="install-summary" aria-label="What the desktop app includes">
      <div data-reveal data-interactive>
        <span>Runs locally</span>
        <strong>Provider sessions start from your machine and project folders.</strong>
      </div>
      <div data-reveal data-interactive>
        <span>Keeps context</span>
        <strong>Threads retain terminal, browser, editor, GitHub, and diff state.</strong>
      </div>
      <div data-reveal data-interactive>
        <span>Recovers work</span>
        <strong>Checkpoints, approvals, reconnects, and history stay visible.</strong>
      </div>
    </section>

    <section id="downloads" class="platform-grid" aria-label="All downloads">
      <article class="platform-card" data-reveal data-interactive>
        <div class="platform-heading">
          <svg class="platform-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" aria-hidden="true"><path fill="currentColor" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>
          <h2>macOS</h2>
        </div>
        <a
          class="asset-card"
          data-download-card
          data-key="mac-arm64"
          data-patterns="arm64.dmg,aarch64.dmg"
          href="#downloads"
          aria-disabled="true"
          data-interactive
        >
          <strong>Apple Silicon</strong>
          <span>.dmg for M-series Macs</span>
        </a>
        <a
          class="asset-card"
          data-download-card
          data-key="mac-x64"
          data-patterns="x64.dmg,x86_64.dmg,amd64.dmg"
          href="#downloads"
          aria-disabled="true"
          data-interactive
        >
          <strong>Intel Mac</strong>
          <span>.dmg for x64 Macs</span>
        </a>
      </article>

      <article class="platform-card" data-reveal data-interactive>
        <div class="platform-heading">
          <svg class="platform-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/></svg>
          <h2>Windows</h2>
        </div>
        <a
          class="asset-card"
          data-download-card
          data-key="windows-x64"
          data-patterns="x64.exe,x86_64.exe,amd64.exe"
          href="#downloads"
          aria-disabled="true"
          data-interactive
        >
          <strong>Windows 10, 11</strong>
          <span>.exe installer for x64 PCs</span>
        </a>
      </article>

      <article class="platform-card" data-reveal data-interactive>
        <div class="platform-heading">
          <span class="linux-mark" aria-hidden="true">Lx</span>
          <h2>Linux</h2>
        </div>
        <a
          class="asset-card"
          data-download-card
          data-key="linux-x64"
          data-patterns="x86_64.AppImage,x64.AppImage,amd64.AppImage,.AppImage"
          href="#downloads"
          aria-disabled="true"
          data-interactive
        >
          <strong>x86_64</strong>
          <span>AppImage build</span>
        </a>
      </article>
    </section>

    <p class="release-note" data-reveal>
      Need release notes?
      <a href="/changelog">
        View the changelog<span aria-hidden="true"> -></span>
      </a>
    </p>
  </section>
</Layout>

<script>
  import { fetchLatestRelease } from "../lib/releases";

  type PlatformKey = "mac-arm64" | "mac-x64" | "windows-x64" | "linux-x64";

  const PLATFORM_LABELS: Record<PlatformKey, string> = {
    "mac-arm64": "Download for Apple Silicon",
    "mac-x64": "Download for Intel Mac",
    "windows-x64": "Download for Windows",
    "linux-x64": "Download for Linux",
  };

  function detectPlatform(): PlatformKey {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return "windows-x64";
    if (/Mac/i.test(ua)) return /Intel|x86_64/i.test(ua) ? "mac-x64" : "mac-arm64";
    if (/Linux/i.test(ua)) return "linux-x64";
    return "mac-arm64";
  }

  function findAsset(
    assets: Array<{ name: string; browser_download_url: string }>,
    patterns: string[],
  ) {
    return patterns
      .map((pattern) =>
        assets.find((asset) => asset.name.toLowerCase().endsWith(pattern.toLowerCase())),
      )
      .find(Boolean);
  }

  function setCardEnabled(card: HTMLAnchorElement, href: string) {
    card.href = href;
    card.removeAttribute("aria-disabled");
    card.classList.remove("is-disabled");
  }

  function setCardUnavailable(card: HTMLAnchorElement) {
    card.href = "#downloads";
    card.setAttribute("aria-disabled", "true");
    card.classList.add("is-disabled");
  }

  async function initDownloadPage() {
    const recommendedKey = detectPlatform();
    const recommendedButton = document.getElementById("recommended-download") as HTMLAnchorElement | null;
    const recommendedCopy = document.getElementById("recommended-copy");
    const versionLabel = document.getElementById("version-label");
    const cards = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-download-card]"));

    if (recommendedCopy) {
      recommendedCopy.textContent = PLATFORM_LABELS[recommendedKey];
    }

    try {
      const release = await fetchLatestRelease();
      const assets = release.assets ?? [];

      if (versionLabel) {
        versionLabel.textContent = release.tag_name ? `Latest release ${release.tag_name}` : "Latest release";
      }
      cards.forEach((card) => {
        const patterns = (card.dataset.patterns ?? "").split(",").filter(Boolean);
        const match = findAsset(assets, patterns);
        if (match) {
          setCardEnabled(card, match.browser_download_url);
        } else {
          setCardUnavailable(card);
        }
      });

      const recommendedCard = cards.find((card) => card.dataset.key === recommendedKey);
      if (recommendedButton && recommendedCard?.href && recommendedCard.getAttribute("aria-disabled") !== "true") {
        recommendedButton.href = recommendedCard.href;
        recommendedButton.classList.remove("is-disabled");
        recommendedButton.removeAttribute("aria-disabled");
        recommendedButton.querySelector("span")!.textContent = PLATFORM_LABELS[recommendedKey];
      } else if (recommendedButton) {
        recommendedButton.querySelector("span")!.textContent = "Download unavailable";
      }
    } catch {
      if (versionLabel) {
        versionLabel.textContent = "Release information unavailable";
      }
      if (recommendedButton) {
        recommendedButton.querySelector("span")!.textContent = "Download unavailable";
      }
      cards.forEach(setCardUnavailable);
    }
  }

  initDownloadPage();
</script>

<style>
  .download-page {
    width: min(100% - 2rem, 1240px);
    margin: 0 auto;
    padding: 0 0 clamp(4rem, 8vw, 7rem);
  }

  .download-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.5rem;
    border-bottom: 1px solid var(--line);
  }

  .download-brand,
  .home-link {
    display: inline-flex;
    align-items: center;
    color: var(--fg);
    font-weight: 800;
  }

  .download-brand {
    gap: 0.65rem;
  }

  .download-brand img {
    width: 2rem;
    height: 2rem;
    border-radius: 7px;
  }

  .home-link {
    position: relative;
    gap: 0.35rem;
    color: var(--fg-muted);
    font-size: 0.94rem;
    transition: color 150ms ease;
  }

  .home-link svg {
    width: 0.9rem;
    height: 0.9rem;
    transition: transform 150ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .home-link:hover {
    color: var(--fg);
  }

  .home-link:hover svg {
    transform: translate3d(2px, -2px, 0);
  }

  .download-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(24rem, 0.58fr);
    gap: 4rem;
    align-items: end;
    min-height: min(34rem, calc(100svh - 4.5rem));
    padding: 2rem 0 1.75rem;
  }

  .download-copy {
    display: grid;
    gap: 1rem;
    max-width: 47rem;
  }

  .small-line {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .download-hero h1 {
    color: var(--fg);
    font-size: 4.8rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.94;
    text-wrap: balance;
  }

  .download-hero p:not(.small-line) {
    max-width: 42rem;
    color: var(--fg-muted);
    font-size: 1.06rem;
    line-height: 1.62;
  }

  .recommended-download {
    display: grid;
    gap: 1.3rem;
    align-content: start;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: rgba(244, 241, 232, 0.04);
    padding: 1.25rem;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      box-shadow 220ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .recommended-download:hover {
    border-color: rgba(244, 241, 232, 0.36);
    background: rgba(244, 241, 232, 0.055);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.26);
    transform: translateY(-2px);
  }

  #version-label {
    display: block;
    margin-bottom: 0.9rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }

  .recommended-download h2 {
    color: var(--fg);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.02;
  }

  .recommended-download p {
    margin-top: 0.65rem;
    color: var(--fg-muted);
    font-size: 0.98rem;
  }

  .download-button {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 7px;
    background: var(--surface-strong);
    color: var(--ink);
    padding: 0.84rem 1rem;
    font-weight: 800;
    text-align: center;
    white-space: nowrap;
    transition:
      box-shadow 160ms ease,
      transform 160ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 160ms ease;
  }

  .download-button:not(.is-disabled):hover {
    box-shadow: 0 16px 38px rgba(244, 241, 232, 0.12);
    transform: translateY(-1px);
  }

  .install-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin-bottom: 1rem;
  }

  .install-summary div {
    display: grid;
    gap: 0.35rem;
    min-height: 6.3rem;
    align-content: center;
    padding: 1rem 1.1rem;
    transition:
      background 180ms ease,
      transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .install-summary div:hover {
    background: rgba(244, 241, 232, 0.035);
    transform: translateY(-1px);
  }

  .install-summary div + div {
    border-left: 1px solid var(--line);
  }

  .install-summary span {
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  .install-summary strong {
    color: var(--fg);
    font-size: 1.03rem;
    line-height: 1.28;
  }

  .platform-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .platform-card {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    min-height: 15rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(244, 241, 232, 0.026);
    padding: 1rem;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .platform-card:hover {
    border-color: var(--line-strong);
    background: rgba(244, 241, 232, 0.04);
    transform: translateY(-2px);
  }

  .platform-heading {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.35rem;
  }

  .platform-heading h2 {
    color: var(--fg);
    font-size: 1.15rem;
    font-weight: 800;
  }

  .platform-icon,
  .linux-mark {
    width: 1.15rem;
    height: 1.15rem;
    color: var(--fg);
  }

  .linux-mark {
    display: inline-grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 800;
  }

  .asset-card {
    display: grid;
    gap: 0.25rem;
    border: 1px solid var(--line);
    border-radius: 7px;
    background: rgba(11, 12, 14, 0.52);
    padding: 0.85rem;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      transform 180ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 160ms ease;
  }

  .asset-card:hover {
    border-color: var(--line-strong);
    background: rgba(244, 241, 232, 0.055);
    transform: translateX(3px);
  }

  .asset-card strong {
    color: var(--fg);
    font-size: 0.98rem;
  }

  .asset-card span {
    color: var(--fg-muted);
    font-size: 0.88rem;
  }

  .is-disabled {
    cursor: not-allowed;
    opacity: 0.48;
  }

  .release-note {
    margin-top: 1.35rem;
    color: var(--fg-dim);
    font-size: 0.92rem;
  }

  .release-note a {
    color: var(--fg-muted);
    font-weight: 800;
  }

  @media (max-width: 900px) {
    .download-hero {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      min-height: auto;
      padding-top: 2rem;
    }

    .download-hero h1 {
      font-size: 3.25rem;
    }

    .recommended-download {
      gap: 1rem;
    }

    .install-summary,
    .platform-grid {
      grid-template-columns: 1fr;
    }

    .install-summary div + div {
      border-top: 1px solid var(--line);
      border-left: 0;
    }

    .platform-grid {
      grid-template-columns: 1fr;
    }

    .platform-card {
      min-height: auto;
    }
  }

  @media (max-width: 640px) {
    .download-page {
      width: min(100% - 1rem, 1240px);
    }

    .download-nav {
      min-height: 4rem;
    }

    .download-hero h1 {
      font-size: 2.7rem;
    }

    .download-button {
      width: 100%;
    }
  }
</style>
