---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ace",
  description = "ace is a fast, minimal GUI for coding agents.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/screenshot.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/screenshot.png" />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@400,500,700,800&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="page">
      <main id="content" class="main">
        <slot />
      </main>

      <footer class="footer">
        <div class="footer-brand-block">
          <a href="/" class="footer-brand">
            <img src="/logo.png" alt="" />
            <span>ace</span>
          </a>
          <p class="footer-copy">
            Agent operations for real codebases: threads, review, recovery, and provider handoff in
            one workspace.
          </p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/arpan404/ace" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://discord.gg/jn4EGJjrvv" target="_blank" rel="noopener noreferrer">Discord</a>
          <a href="/changelog">Changelog</a>
          <a href="mailto:contact@arpan.sh">Contact</a>
        </div>
      </footer>
    </div>
  </body>
</html>

<script>
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!reducedMotion) {
    document.documentElement.classList.add("motion-ready");
    const revealItems = Array.from(document.querySelectorAll<HTMLElement>("[data-reveal]"));
    const scroll3dItems = Array.from(document.querySelectorAll<HTMLElement>("[data-scroll-3d]"));

    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          revealObserver.unobserve(entry.target);
        });
      },
      { rootMargin: "0px 0px -12% 0px", threshold: 0.12 },
    );

    revealItems.forEach((item, index) => {
      item.style.setProperty("--reveal-delay", `${Math.min(index * 42, 220)}ms`);
      revealObserver.observe(item);
    });

    if (scroll3dItems.length > 0) {
      let scrollFrame = 0;

      const updateScroll3d = () => {
        scrollFrame = 0;
        const viewportHeight = window.innerHeight || 1;
        const viewportCenter = viewportHeight / 2;

        scroll3dItems.forEach((item) => {
          const rect = item.getBoundingClientRect();
          if (rect.bottom < -160 || rect.top > viewportHeight + 160) return;

          const center = rect.top + rect.height / 2;
          const rawProgress = (center - viewportCenter) / viewportCenter;
          const progress = Math.max(-1, Math.min(1, rawProgress));
          const strength = Number(item.dataset.scrollStrength ?? "1");
          const rotateX = -progress * 5.2 * strength;
          const rotateY = progress * 2.8 * strength;
          const translateY = -progress * 18 * strength;
          const scale = 1 - Math.abs(progress) * 0.018 * strength;
          const shadow = 1 - Math.abs(progress) * 0.22;

          item.style.setProperty("--scroll-rotate-x", `${rotateX.toFixed(3)}deg`);
          item.style.setProperty("--scroll-rotate-y", `${rotateY.toFixed(3)}deg`);
          item.style.setProperty("--scroll-translate-y", `${translateY.toFixed(3)}px`);
          item.style.setProperty("--scroll-scale", scale.toFixed(4));
          item.style.setProperty("--scroll-shadow", shadow.toFixed(4));
        });
      };

      const requestScroll3dUpdate = () => {
        if (scrollFrame) return;
        scrollFrame = window.requestAnimationFrame(updateScroll3d);
      };

      updateScroll3d();
      window.addEventListener("scroll", requestScroll3dUpdate, { passive: true });
      window.addEventListener("resize", requestScroll3dUpdate);
    }
  }

  document.querySelectorAll<HTMLElement>("[data-interactive]").forEach((element) => {
    element.addEventListener("pointermove", (event) => {
      const rect = element.getBoundingClientRect();
      element.style.setProperty("--pointer-x", `${event.clientX - rect.left}px`);
      element.style.setProperty("--pointer-y", `${event.clientY - rect.top}px`);
    });

    element.addEventListener("pointerdown", () => {
      element.classList.add("is-pressing");
    });

    for (const eventName of ["pointerup", "pointercancel", "pointerleave", "blur"]) {
      element.addEventListener(eventName, () => {
        element.classList.remove("is-pressing");
      });
    }
  });
</script>

<style is:global>
  :root {
    --bg: #05080d;
    --bg-soft: #0a0f16;
    --surface: #0f141d;
    --surface-strong: #edf2fb;
    --ink: #0d1219;
    --fg: #edf2fb;
    --fg-muted: rgba(237, 242, 251, 0.74);
    --fg-dim: rgba(237, 242, 251, 0.5);
    --primary: #d3dae4;
    --primary-deep: #7b8694;
    --accent: #d3dae4;
    --accent-deep: #7b8694;
    --review: #b9c0c9;
    --risk: #f1786d;
    --success: #bcc6d2;
    --clay: #96a0ad;
    --line: rgba(237, 242, 251, 0.12);
    --line-strong: rgba(237, 242, 251, 0.23);
    --border: var(--line);
    --border-bright: var(--line-strong);
    --accent-glow: rgba(211, 218, 228, 0.16);
    --shadow: rgba(0, 0, 0, 0.42);
    --radius: 10px;
    --font-sans: "Cabinet Grotesk", "Avenir Next", "Helvetica Neue", sans-serif;
    --font-mono: "JetBrains Mono", "SFMono-Regular", monospace;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    color-scheme: dark;
    scroll-behavior: smooth;
    background: var(--bg);
  }

  body {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at top left, rgba(207, 216, 227, 0.04), transparent 24%),
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.02), transparent 20%),
      linear-gradient(180deg, #090d14 0%, #05080d 28rem, #05080d 100%);
    color: var(--fg);
    font-family: var(--font-sans);
    font-feature-settings: "ss01" 1, "ss03" 1;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  svg {
    display: block;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  a:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .motion-ready [data-reveal] {
    opacity: 0;
    transform: translate3d(0, 18px, 0);
    transition:
      opacity 360ms ease,
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  .motion-ready [data-reveal].is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .motion-ready [data-scroll-3d] {
    --scroll-rotate-x: 0deg;
    --scroll-rotate-y: 0deg;
    --scroll-translate-y: 0px;
    --scroll-scale: 1;
    --scroll-shadow: 1;
    transform: perspective(1100px) rotateX(var(--scroll-rotate-x)) rotateY(var(--scroll-rotate-y))
      translate3d(0, var(--scroll-translate-y), 0) scale(var(--scroll-scale));
    transform-style: preserve-3d;
    will-change: transform;
  }

  [data-interactive] {
    --pointer-x: 50%;
    --pointer-y: 50%;
    position: relative;
    overflow: hidden;
  }

  [data-interactive]::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      circle at var(--pointer-x) var(--pointer-y),
      rgba(255, 255, 255, 0.16),
      transparent 34%
    );
    opacity: 0;
    transition: opacity 160ms ease;
  }

  [data-interactive]:hover::before,
  [data-interactive]:focus-visible::before {
    opacity: 1;
  }

  [data-interactive].is-pressing {
    transform: translateY(1px) scale(0.992);
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
      transition-duration: 0.001ms !important;
    }

    .motion-ready [data-reveal] {
      opacity: 1;
      transform: none;
    }
  }

  .skip-link {
    position: fixed;
    left: 1rem;
    top: 1rem;
    z-index: 20;
    transform: translateY(-180%);
    border-radius: 6px;
    background: var(--surface-strong);
    color: var(--ink);
    padding: 0.7rem 0.9rem;
    font-weight: 700;
    transition: transform 180ms ease;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }
</style>

<style>
  .page {
    position: relative;
    z-index: 2;
    display: flex;
    min-height: 100vh;
    flex-direction: column;
  }

  .footer-links {
    display: flex;
    align-items: center;
  }

  .main {
    display: flex;
    flex: 1;
    width: 100%;
    max-width: 100%;
    flex-direction: column;
    overflow-x: hidden;
  }

  .footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    width: min(100% - 2rem, 1180px);
    margin: 0 auto;
    border-top: 1px solid var(--line);
    padding: 2.4rem 0 3rem;
  }

  .footer-brand-block {
    display: grid;
    gap: 0.75rem;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.05rem;
    font-weight: 800;
  }

  .footer-brand img {
    width: 2rem;
    height: 2rem;
    border-radius: 0.7rem;
  }

  .footer-copy {
    max-width: 30rem;
    color: var(--fg-dim);
    font-size: 0.96rem;
  }

  .footer-links {
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.35rem 1rem;
  }

  .footer-links a {
    color: var(--fg-muted);
    font-size: 0.94rem;
    font-weight: 700;
    transition: color 180ms ease;
  }

  .footer-links a:hover {
    color: var(--fg);
  }

  @media (max-width: 780px) {
    .footer {
      align-items: flex-start;
      flex-direction: column;
      padding-bottom: 2rem;
    }

    .footer-links {
      justify-content: flex-start;
    }
  }
</style>
