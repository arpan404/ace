---
---

<aside class="replica-sidebar">
  <div class="sidebar-topbar">
    <span class="brand">ace</span>
    <button class="rail-button" aria-label="Toggle sidebar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <rect x="4" y="5" width="16" height="14" rx="2"></rect>
        <path d="M10 5v14"></path>
      </svg>
    </button>
  </div>

  <div class="search-row">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <circle cx="11" cy="11" r="7"></circle>
      <path d="m20 20-3.5-3.5"></path>
    </svg>
    <span>Search</span>
    <kbd>⌘K</kbd>
  </div>

  <p class="section-label">PROJECTS</p>
  <div class="project-row active">
    <span class="status-dot"></span>
    <span class="project-name">ace</span>
  </div>
  <div class="thread-item active">
    <span class="thread-title">Fix build error and redesign site</span>
    <span class="thread-time">29s ago</span>
  </div>
  <div class="thread-item">
    <span class="thread-title">Astro syntax error in index</span>
    <span class="thread-time">7h ago</span>
  </div>

  <div class="sidebar-spacer"></div>
  <button class="settings-row">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <circle cx="12" cy="12" r="3"></circle>
      <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
    </svg>
    Settings
  </button>
</aside>

<style>
  .replica-sidebar {
    background: var(--replica-sidebar);
    border-right: 1px solid var(--replica-border);
    padding: 12px;
    display: flex;
    min-height: 0;
    flex-direction: column;
    color: var(--replica-fg);
    gap: 10px;
  }

  .sidebar-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 34px;
  }

  .brand {
    font-size: 30px;
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 600;
  }

  .rail-button {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    border: 1px solid var(--replica-border);
    background: rgba(255, 255, 255, 0.03);
    color: var(--replica-fg-dim);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .rail-button svg {
    width: 14px;
    height: 14px;
  }

  .search-row {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 34px;
    border: 1px solid var(--replica-border);
    border-radius: 10px;
    padding: 0 10px;
    color: var(--replica-fg-dim);
    font-size: 12px;
  }

  .search-row svg {
    width: 13px;
    height: 13px;
    opacity: 0.75;
  }

  .search-row kbd {
    margin-left: auto;
    font: inherit;
    font-size: 11px;
    color: var(--replica-fg-muted);
    border: 1px solid var(--replica-border);
    border-radius: 6px;
    padding: 1px 5px;
  }

  .section-label {
    margin: 6px 0 0;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--replica-fg-muted);
  }

  .project-row {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 30px;
    padding: 0 8px;
    border-radius: 8px;
  }

  .project-row.active {
    background: rgba(255, 255, 255, 0.04);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: #46db80;
    box-shadow: 0 0 0 3px rgba(70, 219, 128, 0.16);
  }

  .project-name {
    font-size: 13px;
    color: var(--replica-fg);
  }

  .thread-item {
    display: grid;
    gap: 2px;
    border-radius: 8px;
    padding: 8px 9px;
    border: 1px solid transparent;
  }

  .thread-item.active {
    border-color: var(--replica-border);
    background: rgba(255, 255, 255, 0.03);
  }

  .thread-title {
    font-size: 12px;
    color: var(--replica-fg);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .thread-time {
    font-size: 11px;
    color: var(--replica-fg-muted);
  }

  .sidebar-spacer {
    flex: 1;
    min-height: 8px;
  }

  .settings-row {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 32px;
    width: 100%;
    justify-content: flex-start;
    border: 1px solid var(--replica-border);
    border-radius: 9px;
    padding: 0 9px;
    color: var(--replica-fg-dim);
    background: rgba(255, 255, 255, 0.03);
    font-size: 12px;
  }

  .settings-row svg {
    width: 13px;
    height: 13px;
  }
</style>
