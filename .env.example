# Example environment variables for local development
# Copy this to .env and edit as needed (do NOT commit secrets to git)

# Relay pairing server (centralized)
ACE_RELAY_SERVER_URL=http://127.0.0.1:3780
RELAY_HOST=0.0.0.0
RELAY_PORT=3780
RELAY_PUBLIC_URL=http://127.0.0.1:3780

# Host server overrides
#ACE_HOST=192.168.1.100
#ACE_PORT=3777

# Development toggles
#ACE_NO_BROWSER=0
#ACE_LOG_WS_EVENTS=0
